            vector_graph_properties=[],
            variable_len_graph_properties=[]
        )
        
        handler = create_dataset_handler(
            dataset_config, filter_config, processing_config, logger
        )
        
        assert isinstance(handler, DMCDatasetHandler)
        assert handler.get_dataset_type() == "DMC"
        log("    Factory creates DMC handler correctly")
    
    def test_factory_unknown_type():
        """Test factory rejects unknown dataset type."""
        try:
            dataset_config = DatasetConfig(
                dataset_type="UNKNOWN_TYPE"
            )
            # If we get here, DatasetConfig validates the type before factory
            raise AssertionError("DatasetConfig should have rejected UNKNOWN_TYPE")
        except (ValueError, HandlerNotAvailableError, ConfigurationError) as e:
            # Accept any of these exception types as proper rejection
            assert "UNKNOWN_TYPE" in str(e) or "Must be one of" in str(e)
            log("    Factory/Config properly rejects unknown types")
    
    test_case("6.1 Factory - DFT Handler", test_factory_dft)
    test_case("6.2 Factory - DMC Handler", test_factory_dmc)
    test_case("6.3 Factory - Unknown Type", test_factory_unknown_type)
    
    # ========================================================================
    # TEST 7: Exception Handling
    # ========================================================================
    
    def test_handler_exceptions():
        """Test exception types are used."""
        dataset_config = DatasetConfig(
            dataset_type="DFT"
        )
        filter_config = FilterConfig()
        processing_config = ProcessingConfig(
            scalar_graph_targets=['Etot'],
            node_features=[],
            vector_graph_properties=[],
            variable_len_graph_properties=[]
        )
        
        handler = DFTDatasetHandler(
            dataset_config, filter_config, processing_config, logger
        )
        
        # Test validation with missing data
        try:
            handler.validate_molecule_data(
                raw_properties_dict={},
                molecule_index=0,
                identifier="test"
            )
            raise AssertionError("Should have raised HandlerValidationError")
        except HandlerValidationError as e:
            assert "Missing required DFT properties" in str(e)
            log("    DFT validation properly raises HandlerValidationError")
    
    test_case("7.1 Handler Exception Types", test_handler_exceptions)
    
    # ========================================================================
    # SUMMARY
    # ========================================================================
    
    print("\n" + "="*80)
    print("SMOKE TEST SUMMARY")
    print("="*80)
    print(f"Passed: {passed}")
    print(f"Failed: {failed}")
    print(f"Total:  {passed + failed}")
    
    if failed == 0:
        print("\n✓ ALL SMOKE TESTS PASSED")
    else:
        print(f"\n✗ {failed} SMOKE TEST(S) FAILED")
    
    print("="*80 + "\n")
        
