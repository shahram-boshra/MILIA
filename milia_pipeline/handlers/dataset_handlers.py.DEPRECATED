        'type': 'WavefunctionDatasetHandler',
        'has_internal_scalar_targets': hasattr(WavefunctionDatasetHandler, '_add_scalar_targets_internal'),
        'has_tensor_utilities': hasattr(WavefunctionDatasetHandler, '_ensure_tensor'),
