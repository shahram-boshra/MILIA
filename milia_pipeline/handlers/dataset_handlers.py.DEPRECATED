            variable_len_graph_properties=[]
        )
        
        handler = DFTDatasetHandler(
            dataset_config, filter_config, processing_config, logger
        )
        
        # Test various input types
        tensor_from_float = handler._ensure_tensor(3.14, property_name="test_float")
        assert abs(tensor_from_float.item() - 3.14) < 0.001
        
        tensor_from_list = handler._ensure_tensor([1.0, 2.0, 3.0], property_name="test_list")
        assert tensor_from_list.shape == (3,)
        
        tensor_from_numpy = handler._ensure_tensor(
            np.array([1.0, 2.0]), property_name="test_numpy"
        )
        assert tensor_from_numpy.shape == (2,)
        
        log("    Tensor conversion handles multiple input types")
    
