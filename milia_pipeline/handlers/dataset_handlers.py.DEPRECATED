if __name__ == "__main__":
    print("\n" + "="*80)
    print("DATASET HANDLERS - SMOKE TEST")
    print("="*80 + "\n")
    
    # Set up logging
    import logging
    logging.basicConfig(level=logging.INFO)
    logger = logging.getLogger(__name__)
    
    passed = 0
    failed = 0
    
    def test_case(name, func):
        global passed, failed
        try:
            print(f"\n[TEST] {name}")
            func()
            print(f"  ✓ PASSED")
            passed += 1
        except AssertionError as e:
            print(f"  ✗ FAILED: {e}")
            failed += 1
        except Exception as e:
            print(f"  ✗ ERROR: {e}")
            failed += 1
    
    def log(msg):
        print(msg)
    
    # Import transforms with availability checking
    from torch_geometric import transforms
    from torch_geometric.transforms import Compose, AddSelfLoops, ToUndirected
    
    # Helper function to check transform availability
    def get_available_transform(transform_name):
        """Get transform class if available, None otherwise."""
        try:
            return getattr(transforms, transform_name, None)
        except AttributeError:
            return None
    
    # Helper function to create safe transform sequence
    def create_safe_transform_sequence():
        """Create transform sequence with only available transforms."""
        available_transforms = []
        
        # Try to add common transforms if available
        transform_candidates = [
            ('AddSelfLoops', AddSelfLoops),
            ('ToUndirected', ToUndirected),
        ]
        
        for name, transform_cls in transform_candidates:
            if transform_cls is not None:
                try:
                    available_transforms.append(transform_cls())
                except Exception as e:
                    logger.debug(f"Could not instantiate {name}: {e}")
        
        # Only create Compose if we have transforms
        if available_transforms:
            return Compose(available_transforms)
        else:
            return None

