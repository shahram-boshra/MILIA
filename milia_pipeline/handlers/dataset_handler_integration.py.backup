# =============================================================================
# SECTION 3: ADVANCED VALIDATION PATTERNS
# =============================================================================

def demonstrate_multi_level_validation_complete():
    """
    Show COMPLETE multi-level validation workflow with handlers.
    
    Basic → Semantic → Dataset-Aware → Production validation
    with all implemented validators from graph_transforms.py.
    
    Validation Pyramid:
    Level 1 (Basic): Parameter types, ranges, required fields
    Level 2 (Semantic): Transform ordering, conflicts, anti-patterns
    Level 3 (Dataset-Aware): DFT/DMC/MD compatibility, metadata preservation
    Level 4 (Production): Performance, safety, resource constraints
    """
    
    example_code = '''
# Example: Complete Multi-Level Validation with All relevant Validators

from milia_pipeline.transformations.graph_transforms import (
    TransformValidator,
    SemanticValidator,
    DatasetAwareValidator,
    ValidationReporter
)
from milia_pipeline.handlers import create_dataset_handler

logger = logging.getLogger(__name__)

# Initialize validators in hierarchy
basic_validator = TransformValidator(registry, logger)
semantic_validator = SemanticValidator(basic_validator, logger)
dataset_validator = DatasetAwareValidator(semantic_validator, logger)
reporter = ValidationReporter()

# Load experimental setup
transforms = config_bridge.load_transforms_from_config(
    experimental_setup="with_pe"
)

# Create handler for dataset-specific validation
handler = create_dataset_handler(dataset_config, filter_config, processing_config, logger)
dataset_type = handler.get_dataset_type()

# =============================================================================
# LEVEL 1: Basic Validation (Parameter Types & Ranges)
# =============================================================================
logger.info("Level 1: Basic Validation...")
basic_issues = []

for transform in transforms:
    transform_config = {
        'name': transform.__class__.__name__,
        'params': transform.__dict__
    }
    issues = basic_validator.validate_transform_config(transform_config)
    if issues:
        basic_issues.extend(issues)

if basic_issues:
    logger.error(f"✗ Basic validation failed: {len(basic_issues)} issues")
    for issue in basic_issues:
        logger.error(f"  - {issue}")
    return False
else:
    logger.info("✓ Basic validation passed")

# =============================================================================
# LEVEL 2: Semantic Validation (Ordering & Conflicts)
# =============================================================================
logger.info("Level 2: Semantic Validation...")
semantic_issues = semantic_validator.validate_transform_sequence(transforms)

if semantic_issues:
    logger.warning(f"⚠ Semantic issues detected: {len(semantic_issues)}")
    for issue in semantic_issues:
        logger.warning(f"  - {issue}")
else:
    logger.info("✓ Semantic validation passed")

# =============================================================================
# LEVEL 3: Dataset-Aware Validation (Handler Requirements)
# =============================================================================
logger.info(f"Level 3: Dataset-Aware Validation ({dataset_type})...")
dataset_issues = dataset_validator.validate_for_dataset_type(
    transforms,
    dataset_type=dataset_type
)

if dataset_issues:
    logger.warning(f"⚠ Dataset-specific issues: {len(dataset_issues)}")
    for issue in dataset_issues:
        logger.warning(f"  - {issue}")
    
    critical_issues = [i for i in dataset_issues if 'ERROR' in i.upper()]
    if critical_issues:
        logger.error("✗ Critical dataset compatibility issues found")
        return False
else:
    logger.info("✓ Dataset-aware validation passed")

# =============================================================================
# LEVEL 4: Production Validation (Performance & Safety)
# =============================================================================
logger.info("Level 4: Production Validation...")

resource_issues = dataset_validator.validate_resource_usage(transforms)
if resource_issues:
    logger.warning(f"⚠ Resource concerns: {resource_issues}")

safety_issues = dataset_validator.validate_safety_constraints(transforms)
if safety_issues:
    logger.error(f"✗ Safety issues: {safety_issues}")
    return False

logger.info("✓ Production validation passed")

# =============================================================================
# Generate Comprehensive Report
# =============================================================================
validation_results = {
    'basic': {'passed': len(basic_issues) == 0, 'issues': basic_issues},
    'semantic': {'passed': len(semantic_issues) == 0, 'issues': semantic_issues},
    'dataset_aware': {'passed': len(dataset_issues) == 0, 'issues': dataset_issues},
    'production': {'passed': True, 'issues': []},
    'overall_passed': len(basic_issues) == 0 and len(critical_issues) == 0
}

text_report = reporter.generate_report(validation_results, format='text')
logger.info("\\n" + text_report)

json_report = reporter.generate_report(validation_results, format='json')
with open('validation_report.json', 'w') as f:
    f.write(json_report)

logger.info("\\n✓ All validation levels completed!")
logger.info(f"Overall Status: {'PASSED' if validation_results['overall_passed'] else 'FAILED'}")
'''
    
    return example_code


def demonstrate_dynamic_transform_discovery_workflow():
    """
    Demonstrate dynamic transform discovery with version compatibility.
    
    FEATURE: Automatically discover available transforms,
    check version compatibility, and filter by dataset requirements.
    """
    
    example_code = '''
# ============================================================================
# Dynamic Transform Discovery - Automatic Detection
# ============================================================================

from milia_pipeline.transformations.graph_transforms import DynamicTransformDiscovery
import logging

logger = logging.getLogger(__name__)

discovery = DynamicTransformDiscovery()

# ==========================================================================
# STEP 1: Discover All Available Transforms
# ==========================================================================

available_transforms = discovery.discover_available_transforms()

logger.info(f"Discovered {len(available_transforms)} transforms")
for name, transform_class in available_transforms.items():
    logger.info(f"  • {name}: {transform_class}")


# ==========================================================================
# STEP 2: Auto-Categorize Transforms
# ==========================================================================

categorized = discovery.auto_categorize_transforms(available_transforms)

logger.info("\\nTransform Categories:")
for category, transforms in categorized.items():
    logger.info(f"  {category}: {len(transforms)} transforms")
    for transform_name in transforms[:3]:
        logger.info(f"    - {transform_name}")


# ==========================================================================
# STEP 3: Filter by Dataset Compatibility
# ==========================================================================

# Filter for DFT dataset (requires coordinate preservation)
dft_compatible = discovery.filter_compatible_transforms(
    available_transforms,
    dataset_type="DFT",
    preserve_coordinates=True,
    preserve_properties=['pos', 'x', 'y']
)

logger.info(f"\\nDFT-compatible transforms: {len(dft_compatible)}")
for name in list(dft_compatible.keys())[:5]:
    logger.info(f"  • {name}")


# Filter for DMC dataset (requires uncertainty metadata)
dmc_compatible = discovery.filter_compatible_transforms(
    available_transforms,
    dataset_type="DMC",
    preserve_metadata=True,
    preserve_properties=['std', 'uncertainty']
)

logger.info(f"\\nDMC-compatible transforms: {len(dmc_compatible)}")
for name in list(dmc_compatible.keys())[:5]:
    logger.info(f"  • {name}")


# ==========================================================================
# STEP 4: Check Version Compatibility
# ==========================================================================

if discovery.is_transform_available("AddLaplacianEigenvectorPE"):
    logger.info("✓ Laplacian PE available in current PyG version")
else:
    logger.warning("✗ Laplacian PE not available - version too old")

if discovery.is_transform_available("RandomNodeSample"):
    logger.info("✓ RandomNodeSample available")
else:
    logger.warning("✗ RandomNodeSample not available")


# ==========================================================================
# STEP 5: Get Transform Metadata
# ==========================================================================

metadata = discovery.get_transform_metadata("AddSelfLoops")
if metadata:
    logger.info(f"\\nAddSelfLoops metadata:")
    logger.info(f"  Module: {metadata.get('module')}")
    logger.info(f"  Category: {metadata.get('category')}")
    logger.info(f"  Available: {metadata.get('available')}")
    logger.info(f"  Parameters: {metadata.get('parameters')}")


# ==========================================================================
# STEP 6: Practical Usage - Build Transform List
# ==========================================================================

def build_safe_transform_list(dataset_type: str) -> list:
    """Build list of safe transforms for dataset type."""
    discovery = DynamicTransformDiscovery()
    available = discovery.discover_available_transforms()
    
    compatible = discovery.filter_compatible_transforms(
        available,
        dataset_type=dataset_type,
        preserve_coordinates=(dataset_type == "DFT"),
        preserve_metadata=(dataset_type == "DMC")
    )
    
    safe_transforms = []
    
    if "AddSelfLoops" in compatible:
        safe_transforms.append("AddSelfLoops")
    
    if "NormalizeFeatures" in compatible:
        safe_transforms.append("NormalizeFeatures")
    elif "Normalize" in compatible:
        safe_transforms.append("Normalize")
    
    if "AddLaplacianEigenvectorPE" in compatible:
        safe_transforms.append("AddLaplacianEigenvectorPE")
    
    return safe_transforms


dft_transforms = build_safe_transform_list("DFT")
logger.info(f"\\nSafe DFT transforms: {dft_transforms}")

dmc_transforms = build_safe_transform_list("DMC")
logger.info(f"Safe DMC transforms: {dmc_transforms}")


# ==========================================================================
# STEP 7: Integration with Config
# ==========================================================================

def validate_experimental_setup(setup_transforms: list, dataset_type: str) -> dict:
    """Validate that all transforms in setup are compatible."""
    discovery = DynamicTransformDiscovery()
    available = discovery.discover_available_transforms()
    compatible = discovery.filter_compatible_transforms(
        available,
        dataset_type=dataset_type
    )
    
    results = {
        'valid': [],
        'invalid': [],
        'warnings': []
    }
    
    for transform_name in setup_transforms:
        if transform_name in compatible:
            results['valid'].append(transform_name)
        elif transform_name in available:
            results['invalid'].append(f"{transform_name} - incompatible with {dataset_type}")
        else:
            results['invalid'].append(f"{transform_name} - not available in PyG version")
    
    return results


experimental_setup = ["AddSelfLoops", "AddLaplacianEigenvectorPE", "NormalizeFeatures"]
validation = validate_experimental_setup(experimental_setup, "DFT")

logger.info(f"\\nSetup validation:")
logger.info(f"  Valid: {validation['valid']}")
logger.info(f"  Invalid: {validation['invalid']}")


# ==========================================================================
# Key Benefits
# ==========================================================================

print("""
Key Benefits of Dynamic Discovery:
1. Automatic detection - no manual transform lists
2. Version compatibility - works across PyG versions
3. Dataset awareness - filters unsafe transforms
4. Fallback support - handles missing transforms gracefully
5. Metadata access - detailed transform information
""")
'''
    
    return example_code


def demonstrate_transform_error_handling():
    """
    Show proper error handling for transform failures.
    
    Validation catches issues early; errors fail fast with clear messages.
    No silent fallbacks - configuration issues should be fixed, not worked around.
    
    Key Principles:
    1. Multi-level validation catches issues BEFORE processing
    2. Invalid configurations FAIL FAST (no silent degradation)
    3. Errors are clear, specific, and actionable
    4. Users fix configuration problems rather than relying on fallbacks
    """
    
    example_code = '''
# ============================================================================
# Error Handling - Fail Fast with Clear Messages
# ============================================================================

from milia_pipeline.handlers.dataset_handler_integration import (
    TransformAwareHandlerIntegrator
)
from milia_pipeline.exceptions import TransformValidationError, TransformError

logger = logging.getLogger(__name__)

try:
    integrator = TransformAwareHandlerIntegrator(
        dataset_config=dataset_config,
        filter_config=filter_config,
        processing_config=processing_config,
        logger=logger,
        experimental_setup="advanced_pe",
        enable_caching=True
    )
    
    if not integrator.validation_results['overall_passed']:
        errors = integrator.validation_results['errors']
        warnings = integrator.validation_results['warnings']
        
        logger.error(f"Transform validation failed for setup 'advanced_pe':")
        for level, error_list in errors.items():
            for error in error_list:
                logger.error(f"  [{level}] {error}")
        
        if warnings:
            logger.warning("Validation warnings:")
            for level, warning_list in warnings.items():
                for warning in warning_list:
                    logger.warning(f"  [{level}] {warning}")
        
        raise TransformValidationError(
            f"Experimental setup 'advanced_pe' failed validation. "
            f"Fix configuration issues before proceeding."
        )
    
    logger.info("✓ Transform validation passed for setup 'advanced_pe'")
    logger.info(f"  Loaded {len(integrator.transforms)} transforms")
    
    processed_data = integrator.process_molecule_with_transforms(mol_data)
    logger.info("✓ Molecule processing successful")
    
except TransformValidationError as e:
    logger.error(f"Configuration error: {e}")
    logger.error("ACTION REQUIRED: Review and fix experimental setup in config.yaml")
    raise
    
except TransformError as e:
    logger.error(f"Transform application failed: {e}")
    logger.error("ACTION REQUIRED: Review transform parameters and data compatibility")
    raise
    
except Exception as e:
    logger.error(f"Unexpected error during processing: {e}")
    logger.exception("Full traceback:")
    raise


# ============================================================================
# Alternative: Validation-Only Check Before Creating Dataset
# ============================================================================

def validate_experimental_setup(setup_name: str) -> bool:
    """Validate an experimental setup without processing data."""
    try:
        integrator = TransformAwareHandlerIntegrator(
            dataset_config=dataset_config,
            filter_config=filter_config,
            processing_config=processing_config,
            logger=logger,
            experimental_setup=setup_name,
            enable_caching=False
        )
        
        if integrator.validation_results['overall_passed']:
            logger.info(f"✓ Setup '{setup_name}' is valid")
            return True
        else:
            logger.error(f"✗ Setup '{setup_name}' validation failed")
            errors = integrator.validation_results['errors']
            for level, error_list in errors.items():
                for error in error_list:
                    logger.error(f"  [{level}] {error}")
            return False
            
    except Exception as e:
        logger.error(f"✗ Setup '{setup_name}' validation failed: {e}")
        return False


# ============================================================================
# Best Practice: Validate Configuration on Startup
# ============================================================================

available_setups = ["baseline", "with_pe", "augmented", "advanced_pe"]
valid_setups = []

for setup_name in available_setups:
    if validate_experimental_setup(setup_name):
        valid_setups.append(setup_name)

if not valid_setups:
    raise ValueError("No valid experimental setups found. Check config.yaml")

logger.info(f"Valid experimental setups: {valid_setups}")

for setup in valid_setups:
    dataset = miliaDataset(..., experimental_setup=setup)
    results = train_and_evaluate(dataset)
'''
    
    return example_code

# === PART_2_END ===

# =============================================================================
# SECTION 4: CONFIGURATION MIGRATION EXAMPLES
# =============================================================================

def demonstrate_config_migration_complete():
    """
    Show COMPLETE configuration format migration from v1 → v2 → v3.
    
    FEATURE: Automatic migration of legacy transform configs with
    validation and backward compatibility preservation.
    
    Version Evolution:
    v1: Ad-hoc transform lists (legacy)
    v2: Named experimental setups 
    v3: Full functional with validation, caching, fallback
    """
    
    example_yaml = '''
# =============================================================================
# VERSION 1 (Legacy Ad-hoc) - DEPRECATED
# =============================================================================
transformations:
  - name: "AddSelfLoops"
  - name: "NormalizeFeatures"

# =============================================================================
# VERSION 2 (Named Setups) 
# =============================================================================
transformations:
  experimental_setups:
    baseline:
      - name: "AddSelfLoops"
      - name: "NormalizeFeatures"
    
    with_augmentation:
      - name: "AddSelfLoops"
      - name: "RandomRotate"
        params:
          degrees: 180
      - name: "NormalizeFeatures"
  
  default_setup: "baseline"

# =============================================================================
# VERSION 3 - CURRENT ✓
# =============================================================================
transformations:
  experimental_setups:
    baseline:
      - name: "AddSelfLoops"
      - name: "NormalizeFeatures"
        params:
          attrs: ["x"]
    
    with_pe:
      - name: "AddSelfLoops"
      - name: "AddLaplacianEigenvectorPE"
        params:
          k: 8
          is_undirected: true
          attr_name: "laplacian_pe"
      - name: "NormalizeFeatures"
        params:
          attrs: ["x", "laplacian_pe"]
    
    augmented:
      - name: "AddSelfLoops"
      - name: "RandomRotate"
        params:
          degrees: 180
          axis: 2
      - name: "RandomJitter"
        params:
          translate: 0.01
      - name: "NormalizeFeatures"
    
    advanced_pe_aug:
      - name: "AddSelfLoops"
      - name: "AddLaplacianEigenvectorPE"
        params:
          k: 16
          is_undirected: true
      - name: "RandomRotate"
        params:
          degrees: 180
          axis: 2
      - name: "NormalizeFeatures"
        params:
          attrs: ["x", "laplacian_pe"]
  
  default_setup: "baseline"
  
  validation:
    enabled: true
    levels:
      - basic
      - semantic
      - dataset_aware
    
    fail_on_errors: true
    warn_on_semantic_issues: true
  
  caching:
    enabled: true
    max_memory_mb: 50
    max_age_seconds: 300
    strategy: "lru"
  
  fallback:
    enable_fallback: true
    fallback_chain:
      - "baseline"
      - "minimal"
      - "none"
    
    log_fallback_usage: true
    track_fallback_statistics: true
  
  dataset_constraints:
    DFT:
      preserve_coordinates: true
      allow_augmentation: false
    
    DMC:
      preserve_metadata: true
      allow_augmentation: true
    
    MD:
      preserve_trajectories: true
      allow_augmentation: false
'''
    
    migration_code = '''
# =============================================================================
# Automatic Configuration Migration using ConfigurationBridge
# =============================================================================

from milia_pipeline.transformations.graph_transforms import ConfigurationBridge, TransformRegistry, TransformValidator

logger = logging.getLogger(__name__)

registry = TransformRegistry(logger)
validator = TransformValidator(registry, logger)
config_bridge = ConfigurationBridge(registry, validator)

# =============================================================================
# STEP 1: Load Legacy Configuration
# =============================================================================
logger.info("Loading legacy configuration...")

legacy_config_v1 = {
    'version': 1,
    'transformations': [
        {'name': 'AddSelfLoops'},
        {'name': 'NormalizeFeatures'}
    ]
}

# =============================================================================
# STEP 2: Detect Configuration Version
# =============================================================================
detected_version = config_bridge.detect_config_version(legacy_config_v1)
logger.info(f"Detected configuration version: v{detected_version}")

if detected_version < 3:
    logger.info(f"Migration needed: v{detected_version} → v3")
else:
    logger.info("Configuration is already v3 (current)")

# =============================================================================
# STEP 3: Perform Automatic Migration
# =============================================================================
logger.info("Performing automatic migration...")

migrated_config = config_bridge.migrate_legacy_config(
    legacy_config_v1,
    target_version=3,
    preserve_behavior=True
)

logger.info(f"✓ Migrated from v{detected_version} to v{migrated_config['version']}")

# =============================================================================
# STEP 4: Validate Migrated Configuration
# =============================================================================
logger.info("Validating migrated configuration...")

validation_result = config_bridge.validate_configuration(migrated_config)

if validation_result.is_valid:
    logger.info("✓ Migration successful and validated!")
    logger.info(f"  - Created {len(migrated_config['experimental_setups'])} setups")
    logger.info(f"  - Added validation rules: {migrated_config['validation']['levels']}")
    logger.info(f"  - Configured caching: {migrated_config['caching']['enabled']}")
    logger.info(f"  - Set up fallback chain: {migrated_config['fallback']['fallback_chain']}")
else:
    logger.error(f"✗ Migration validation failed:")
    for error in validation_result.errors:
        logger.error(f"  - {error}")
    for warning in validation_result.warnings:
        logger.warning(f"  - {warning}")

# =============================================================================
# STEP 5: Save Migrated Configuration
# =============================================================================
logger.info("Saving migrated configuration...")

config_bridge.save_configuration(
    migrated_config,
    output_path="config_v3_migrated.yaml",
    backup_original=True
)

logger.info("✓ Migration complete!")
logger.info("  - New config: config_v3_migrated.yaml")
logger.info("  - Backup: config.yaml.backup")

# =============================================================================
# STEP 6: Verify Behavior Equivalence (Optional but Recommended)
# =============================================================================
logger.info("Verifying behavior equivalence...")

old_transforms = config_bridge.load_transforms_from_legacy_config(legacy_config_v1)
new_transforms = config_bridge.load_transforms_from_config(
    config=migrated_config,
    experimental_setup="baseline"
)

is_equivalent = config_bridge.verify_transform_equivalence(
    old_transforms,
    new_transforms
)

if is_equivalent:
    logger.info("✓ Transform behavior verified equivalent")
else:
    logger.warning("⚠ Transform behavior differs - review migration")

logger.info("\\n" + "="*60)
logger.info("MIGRATION SUMMARY")
logger.info("="*60)
logger.info(f"Version: v{detected_version} → v3")
logger.info(f"Status: {'SUCCESS' if validation_result.is_valid else 'FAILED'}")
logger.info(f"Behavior: {'PRESERVED' if is_equivalent else 'MODIFIED'}")
logger.info("="*60)
'''
    
    return example_yaml + "\n\n" + migration_code


