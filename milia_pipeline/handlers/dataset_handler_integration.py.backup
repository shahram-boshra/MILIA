def demonstrate_testing_patterns() -> str:
    """
    Show testing best practices integrator.
    
    Demonstrates how to test experimental setups, transforms,
    validation, and handler-transform integration.
    """
    example_code = '''
# ============================================================================
# Testing Patterns
# ============================================================================

import pytest
from milia_pipeline.handlers.dataset_handler_integration import (
    TransformAwareHandlerIntegrator
)
from milia_pipeline.config.config_containers import (
    DatasetConfig, FilterConfig, ProcessingConfig
)

# ============================================================================
# Test 1: Experimental Setup Validation
# ============================================================================

def test_experimental_setup_validation():
    """Test that experimental setups validate correctly."""
    dataset_config = DatasetConfig(dataset_type="DFT", ...)
    filter_config = FilterConfig(...)
    processing_config = ProcessingConfig(...)
    
    integrator = TransformAwareHandlerIntegrator(
        dataset_config=dataset_config,
        filter_config=filter_config,
        processing_config=processing_config,
        logger=logger,
        experimental_setup="baseline",
        enable_caching=True
    )
    
    assert integrator.validation_results['overall_passed']
    assert len(integrator.validation_results['errors']) == 0
    
    with pytest.raises(TransformValidationError):
        bad_integrator = TransformAwareHandlerIntegrator(
            ...,
            experimental_setup="nonexistent_setup"
        )


# ============================================================================
# Test 2: Transform Application
# ============================================================================

def test_transform_application():
    """Test that transforms apply correctly to molecular data."""
    integrator = TransformAwareHandlerIntegrator(...)
    
    mol_data = {
        'atoms': test_atoms,
        'coords': test_coords,
        'properties': test_properties,
    }
    
    result = integrator.process_molecule_with_transforms(mol_data)
    
    assert isinstance(result, Data)
    assert hasattr(result, 'x')
    assert hasattr(result, 'edge_index')
    assert hasattr(result, 'y')


# ============================================================================
# Test 3: Dataset Compatibility
# ============================================================================

def test_dft_dmc_compatibility():
    """Test DFT and DMC datasets work with appropriate transforms."""
    dft_integrator = TransformAwareHandlerIntegrator(
        dataset_config=DatasetConfig(dataset_type="DFT"),
        ...,
        experimental_setup="with_pe"
    )
    assert dft_integrator.validation_results['overall_passed']
    
    dmc_integrator = TransformAwareHandlerIntegrator(
        dataset_config=DatasetConfig(dataset_type="DMC"),
        ...,
        experimental_setup="with_pe"
    )
    assert dmc_integrator.validation_results['overall_passed']


# ============================================================================
# Test 4: Cache Performance
# ============================================================================

def test_cache_performance():
    """Test that caching improves performance."""
    integrator = TransformAwareHandlerIntegrator(..., enable_caching=True)
    
    mol_data = {...}
    
    import time
    start = time.time()
    result1 = integrator.process_molecule_with_transforms(mol_data)
    time_uncached = time.time() - start
    
    start = time.time()
    result2 = integrator.process_molecule_with_transforms(mol_data)
    time_cached = time.time() - start
    
    assert time_cached < time_uncached
    
    stats = integrator.cache_manager.get_stats()
    assert stats['hits'] > 0


# ============================================================================
# Test 5: Multi-Setup Comparison
# ============================================================================

def test_multi_setup_comparison():
    """Test comparing multiple experimental setups."""
    setups = ["baseline", "with_pe", "augmented"]
    results = {}
    
    for setup in setups:
        integrator = TransformAwareHandlerIntegrator(
            ...,
            experimental_setup=setup
        )
        
        processed = [
            integrator.process_molecule_with_transforms(mol)
            for mol in test_molecules
        ]
        
        results[setup] = processed
    
    assert len(results['baseline']) == len(results['with_pe'])
'''
    return example_code


def demonstrate_experimental_setup_workflow():
    """
    Demonstrate complete workflow using experimental setups with handlers.
    
    ENHANCEMENT: Systematic experimentation with named setups
    enables ablation studies and reproducible research.
    """
    
    example_code = '''
# Example: Running multiple experimental setups with handlers

from milia_pipeline.config.config_loader import ConfigLoader
from milia_pipeline.handlers import create_dataset_handler
from milia_pipeline.datasets.milia_dataset import miliaDataset

config_loader = ConfigLoader()
config = config_loader.load_config("config.yaml")

experimental_setups = {
    "baseline": ["AddSelfLoops", "NormalizeFeatures"],
    "with_pe": ["AddSelfLoops", "AddLaplacianEigenvectorPE", "NormalizeFeatures"],
    "augmented": ["AddSelfLoops", "RandomRotate", "NormalizeFeatures"]
}

results = {}
for setup_name in experimental_setups.keys():
    logger.info(f"Running experimental setup: {setup_name}")
    
    handler = create_dataset_handler(
        config.dataset_config,
        config.filter_config,
        config.processing_config,
        logger
    )
    
    dataset = miliaDataset(
        root="data/processed",
        raw_dir="data/raw",
        dataset_config=config.dataset_config,
        filter_config=config.filter_config,
        processing_config=config.processing_config,
        experimental_setup=setup_name,
        handler=handler
    )
    
    model_results = train_and_evaluate(dataset, setup_name)
    results[setup_name] = model_results
    
    logger.info(f"Setup '{setup_name}' results: {model_results}")

compare_experimental_results(results)
'''
    
    return example_code


def demonstrate_complete_phase2_workflow():
    """
    Demonstrate COMPLETE end-to-endworkflow.
    
    This comprehensive example shows the full integration of:
    - Dataset handlers
    - Dynamic transform discovery
    - Experimental setups
    - Multi-level validation
    - Transform composition with caching
    - Error recovery with fallback
    - Performance monitoring
    
    Suitable for use as a tutorial or integration test.
    """
    
    example_code = '''
# =============================================================================
# COMPLETE WORKFLOW EXAMPLE
# =============================================================================

import logging
from pathlib import Path

from milia_pipeline.config.config_loader import ConfigLoader
from milia_pipeline.handlers import create_dataset_handler
from milia_pipeline.transformations.graph_transforms import (
    TransformRegistry,
    DynamicTransformDiscovery,
    ConfigurationBridge,
    ValidationReporter,
    IntelligentCacheManager
)
from milia_pipeline.handlers.dataset_handler_integration import TransformAwareHandlerIntegrator
from milia_pipeline.datasets.milia_dataset import miliaDataset

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

# =============================================================================
# STEP 1: Initialize Configuration
# =============================================================================
logger.info("Step 1: Loading configuration...")

config_loader = ConfigLoader()
config = config_loader.load_config("config.yaml")

logger.info(f"✓ Dataset: {config.dataset_config.dataset_type}")
logger.info(f"✓ Available setups: {list(config.transformation_config.experimental_setups.keys())}")

# =============================================================================
# STEP 2: Initialize Transform System Components
# =============================================================================
logger.info("\\nStep 2: Initializing transform system...")

registry = TransformRegistry(logger)
discovery = DynamicTransformDiscovery(logger)
config_bridge = ConfigurationBridge(registry, validator)
cache_manager = IntelligentCacheManager(max_memory_mb=50, logger=logger)

logger.info(f"✓ Registry: {len(registry.list_available_transforms())} transforms")
logger.info("✓ Discovery: Ready for dynamic discovery")
logger.info("✓ Cache: Enabled with 50MB limit")

# =============================================================================
# STEP 3: Create Dataset Handler
# =============================================================================
logger.info("\\nStep 3: Creating dataset handler...")

handler = create_dataset_handler(
    config.dataset_config,
    config.filter_config,
    config.processing_config,
    logger
)

logger.info(f"✓ Handler: {handler.get_dataset_type()}DatasetHandler")
logger.info(f"✓ Required properties: {handler.get_required_properties()}")

# =============================================================================
# STEP 4: Create Transform-Aware Integrator
# =============================================================================
logger.info("\\nStep 4: Creating transform-aware integrator...")

integrator = TransformAwareHandlerIntegrator(
    dataset_config=config.dataset_config,
    filter_config=config.filter_config,
    processing_config=config.processing_config,
    logger=logger,
    experimental_setup="baseline",
    enable_caching=True
)

logger.info("✓ Integrator: Ready with validation and caching")

# =============================================================================
# STEP 5: Run Multiple Experimental Setups
# =============================================================================
logger.info("\\nStep 5: Running experimental setups...")

experimental_setups = ["baseline", "with_pe", "augmented"]
results = {}

for setup_name in experimental_setups:
    logger.info(f"\\n--- Processing setup: {setup_name} ---")
    
    dataset = miliaDataset(
        root=Path("data/processed") / setup_name,
        raw_dir="data/raw",
        dataset_config=config.dataset_config,
        filter_config=config.filter_config,
        processing_config=config.processing_config,
        transformation_config=config.transformation_config,
        experimental_setup=setup_name,
        handler=handler
    )
    
    logger.info(f"✓ Dataset created: {len(dataset)} molecules")
    
    validation_report = integrator.get_validation_report(format='text')
    logger.info(f"\\nValidation Report:\\n{validation_report}")
    
    logger.info(f"Processing {len(dataset)} molecules with setup '{setup_name}'...")
    
    setup_results = {
        'setup': setup_name,
        'molecules': len(dataset),
        'transforms': len(integrator.transforms) if integrator.transforms else 0,
        'validation_passed': integrator.validation_results['overall_passed'],
    }
    
    results[setup_name] = setup_results
    logger.info(f"✓ Setup '{setup_name}' completed")

# =============================================================================
# STEP 6: Compare Experimental Results
# =============================================================================
logger.info("\\n" + "="*70)
logger.info("EXPERIMENTAL RESULTS COMPARISON")
logger.info("="*70)

for setup_name, setup_results in results.items():
    logger.info(f"\\n{setup_name}:")
    logger.info(f"  Molecules: {setup_results['molecules']}")
    logger.info(f"  Transforms: {setup_results['transforms']}")
    logger.info(f"  Validation: {'✓ PASSED' if setup_results['validation_passed'] else '✗ FAILED'}")

# =============================================================================
# STEP 7: Performance Monitoring
# =============================================================================
logger.info("\\n" + "="*70)
logger.info("PERFORMANCE MONITORING")
logger.info("="*70)

cache_stats = integrator.get_cache_statistics()
if cache_stats:
    logger.info(f"\\nCache Performance:")
    logger.info(f"  Hit rate: {cache_stats['hit_rate']:.1%}")
    logger.info(f"  Total hits: {cache_stats['hits']}")
    logger.info(f"  Total misses: {cache_stats['misses']}")
    logger.info(f"  Memory usage: {cache_stats['memory_mb']:.1f} MB")

handler_stats = handler.get_processing_statistics()
logger.info(f"\\nHandler Statistics:")
logger.info(f"  Molecules processed: {handler_stats['molecules_processed']}")
logger.info(f"  Validation failures: {handler_stats['validation_failures']}")
logger.info(f"  Avg processing time: {handler_stats['avg_processing_time_ms']:.2f} ms")

# =============================================================================
# STEP 8: Generate Comprehensive Report
# =============================================================================
logger.info("\\n" + "="*70)
logger.info("GENERATING FINAL REPORT")
logger.info("="*70)

report_path = "experimental_results.json"
with open(report_path, 'w') as f:
    import json
    json.dump(results, f, indent=2)

logger.info(f"✓ Results saved to {report_path}")

markdown_report = f"""
# milia Experimental Results

## Configuration
- Dataset: {config.dataset_config.dataset_type}
- Experimental Setups: {', '.join(experimental_setups)}
- Validation: Enabled (multi-level)
- Caching: Enabled

## Results Summary

"""

for setup_name, setup_results in results.items():
    markdown_report += f"""
### {setup_name}
- Molecules: {setup_results['molecules']}
- Transforms: {setup_results['transforms']}
- Validation: {'PASSED' if setup_results['validation_passed'] else 'FAILED'}

"""

with open("experimental_results.md", 'w') as f:
    f.write(markdown_report)

logger.info("✓ Markdown report saved to experimental_results.md")

logger.info("\\n" + "="*70)
logger.info("WORKFLOW COMPLETE!")
logger.info("="*70)
'''
    
    return example_code

# === PART_3_END ===


def generate_quick_reference_guide() -> str:
    """
    Generate a quick reference guide for features.
    
    This is useful for developers who need a quick reminder of
    available features and how to use them.
    
    Returns:
        Formatted quick reference guide as string
    """
    
    guide = """
╔════════════════════════════════════════════════════════════════════════════╗
║          TRANSFORM SYSTEM - QUICK REFERENCE GUIDE                          ║
╚════════════════════════════════════════════════════════════════════════════╝

┌─ INITIALIZATION ────────────────────────────────────────────────────────────────────────────────────┐
│                                                                                                     │
│ from milia_pipeline.handlers.dataset_handler_integration import TransformAwareHandlerIntegrator     │
│                                                                                                     │
│ integrator = TransformAwareHandlerIntegrator(                                                       │
│     dataset_config=config.dataset_config,                                                           │
│     filter_config=config.filter_config,                                                             │
│     processing_config=config.processing_config,                                                     │
│     logger=logger,                                                                                  │
│     experimental_setup="baseline",  # or "with_pe", "augmented", etc.                               │
│     enable_caching=True             # Enable intelligent caching                                    │
│ )                                                                                                   │
│                                                                                                     │
└─────────────────────────────────────────────────────────────────────────────────────────────────────┘

┌─ VALIDATION ──────────────────────────────────────────────────────────────┐
│                                                                              │
│ # Multi-level validation (automatic during initialization)                  │
│ validation_results = integrator.validation_results                          │
│                                                                              │
│ # Check handler-transform compatibility                                     │
│ warnings = integrator.validate_handler_transform_compatibility(             │
│     pyg_data, raw_properties                                                │
│ )                                                                            │
│                                                                              │
│ # Generate validation report                                                │
│ report = integrator.get_validation_report(format='text')  # or 'json'       │
│ print(report)                                                                │
│                                                                              │
└──────────────────────────────────────────────────────────────────────────────┘

┌─ CACHING & PERFORMANCE ───────────────────────────────────────────────────┐
│                                                                              │
│ # Get cache statistics                                                      │
│ cache_stats = integrator.get_cache_statistics()                             │
│ if cache_stats:                                                              │
│     print(f"Cache hit rate: {cache_stats['hit_rate']:.1%}")                 │
│     print(f"Memory usage: {cache_stats['memory_mb']:.1f} MB")               │
│                                                                              │
└──────────────────────────────────────────────────────────────────────────────┘

┌─ EXPERIMENTAL SETUPS ─────────────────────────────────────────────────────┐
│                                                                              │
│ # Define in config.yaml:                                                    │
│ transformations:                                                             │
│   experimental_setups:                                                       │
│     baseline:                                                                │
│       - name: "AddSelfLoops"                                                 │
│       - name: "NormalizeFeatures"                                            │
│                                                                              │
│     with_pe:                                                                 │
│       - name: "AddSelfLoops"                                                 │
│       - name: "AddLaplacianEigenvectorPE"                                    │
│         params: {k: 8, is_undirected: true}                                  │
│       - name: "NormalizeFeatures"                                            │
│                                                                              │
│ # Use in code:                                                               │
│ dataset = miliaDataset(..., experimental_setup="with_pe")                   │
│                                                                              │
└──────────────────────────────────────────────────────────────────────────────┘

┌─ DYNAMIC DISCOVERY ───────────────────────────────────────────────────────┐
│                                                                              │
│ from milia_pipeline.transformations.graph_transforms import DynamicTransformDiscovery                      │
│                                                                              │
│ discovery = DynamicTransformDiscovery(logger)                               │
│ transforms = discovery.discover_available_transforms()                      │
│ categorized = discovery.auto_categorize_transforms(transforms)              │
│                                                                              │
│ # Filter by dataset compatibility                                           │
│ compatible = discovery.filter_compatible_transforms(                        │
│     transforms,                                                              │
│     dataset_type="DFT",                                                      │
│     preserve_coordinates=True                                                │
│ )                                                                            │
│                                                                              │
└──────────────────────────────────────────────────────────────────────────────┘

┌─ ERROR HANDLING ─────────────────────────────────────────────────────────────┐
│                                                                              │
│ # Validation catches errors BEFORE processing                        │
│                                                                              │
│ try:                                                                         │
│     integrator = TransformAwareHandlerIntegrator(                            │
│         ..., experimental_setup="advanced_pe"                                │
│     )                                                                        │
│                                                                              │
│     # Check validation results                                               │
│     if not integrator.validation_results['overall_passed']:                  │
│         errors = integrator.validation_results['errors']                     │
│         logger.error(f"Validation failed: {errors}")                         │
│         raise TransformValidationError("Fix config before proceeding")       │
│                                                                              │
│     # Proceed with validated setup                                           │
│     processed = integrator.process_molecule_with_transforms(mol_data)        │ 
│                                                                              │
│ except TransformValidationError as e:                                        │
│     logger.error(f"Configuration error: {e}")                                │
│     # Fix experimental setup in config.yaml                                  │
│     raise                                                                    │
│                                                                              │
└──────────────────────────────────────────────────────────────────────────────┘

┌─ CONFIGURATION MIGRATION ─────────────────────────────────────────────────┐
│                                                                              │
│ from milia_pipeline.transformations.graph_transforms import ConfigurationBridge                            │
│                                                                              │
│ config_bridge = ConfigurationBridge(registry, validator)            │
│                                                                              │
│ # Automatic migration from v1/v2 to v3                                      │
│ migrated = config_bridge.migrate_legacy_config(old_config)                  │
│                                                                              │
│ # Validate migrated config                                                  │
│ result = config_bridge.validate_configuration(migrated)                     │
│                                                                              │
└──────────────────────────────────────────────────────────────────────────────┘

┌─ VALIDATION LEVELS ───────────────────────────────────────────────────────┐
│                                                                              │
│ Level 1 - BASIC:          Parameter types, ranges, required fields          │
│ Level 2 - SEMANTIC:       Transform ordering, conflicts, anti-patterns      │
│ Level 3 - DATASET-AWARE:  DFT/DMC/MD compatibility, metadata preservation   │
│ Level 4 - PRODUCTION:     Performance, safety, resource constraints          │
│                                                                              │
│ All levels are automatically checked during integrator initialization.      │
│                                                                              │
└──────────────────────────────────────────────────────────────────────────────┘

┌─ HANDLER-TRANSFORM COMPATIBILITY ─────────────────────────────────────────┐
│                                                                              │
│ PHASE 7: Feature-based compatibility checking                               │
│                                                                              │
│ Dataset Feature        │ Validation Check                                  │
│ ───────────────────────┼─────────────────────────────────────────────────  │
│ uncertainty_handling   │ Preserve uncertainty metadata (std fields)        │
│ vibrational_analysis   │ Preserve coordinates (vibrational modes)          │
│ trajectory_analysis    │ Preserve trajectory information                   │
│ orbital_analysis       │ Preserve orbital-related data                     │
│                                                                              │
│ Validation checks these requirements automatically based on dataset         │
│ features, not hardcoded dataset types. New dataset types with these        │
│ features will automatically receive appropriate validation.                 │
│                                                                              │
└──────────────────────────────────────────────────────────────────────────────┘

┌─ COMMON PATTERNS ─────────────────────────────────────────────────────────┐
│                                                                              │
│ # Pattern 1: Single experimental setup with validation                      │
│ integrator = TransformAwareHandlerIntegrator(                               │
│     ..., experimental_setup="baseline", enable_caching=True                 │
│ )                                                                            │
│ if not integrator.validation_results['overall_passed']:                     │
│     raise ValueError("Setup validation failed")                             │
│ dataset = miliaDataset(..., experimental_setup="baseline")                  │
│                                                                              │
│ # Pattern 2: Compare multiple setups                                        │
│ setups = ["baseline", "with_pe", "augmented"]                               │
│ results = {}                                                                 │
│ for setup in setups:                                                         │
│     integrator = TransformAwareHandlerIntegrator(..., experimental_setup=setup) │
│     if integrator.validation_results['overall_passed']:                     │
│         dataset = miliaDataset(..., experimental_setup=setup)               │
│         results[setup] = train_and_evaluate(dataset)                        │
│     else:                                                                    │
│         logger.warning(f"Setup '{setup}' failed validation - skipping")     │
│                                                                              │
│ # Pattern 3: Validate all setups before training                            │
│ valid_setups = []                                                            │
│ for setup in available_setups:                                               │
│     integrator = TransformAwareHandlerIntegrator(..., experimental_setup=setup) │
│     if integrator.validation_results['overall_passed']:                     │
│         valid_setups.append(setup)                                           │
│ # Train only with valid setups                                              │
│                                                                              │
└──────────────────────────────────────────────────────────────────────────────┘

╔════════════════════════════════════════════════════════════════════════════╗
║  Framework Documentation                                                   ║
║  ────────────────────────────────────────────────────────────────────────  ║
║  Examples: demonstrate_complete_phase2_workflow()                          ║
║  Error Handling: demonstrate_transform_error_handling()                    ║
║  Best Practices: create_integration_checklist()                            ║
║  Performance: create_performance_guide()                                   ║
╚════════════════════════════════════════════════════════════════════════════╝
"""
    
    return guide

# =============================================================================
# DEMONSTRATION FUNCTIONS SUMMARY
# =============================================================================
# 
# Core Demonstrations :
#   - demonstrate_experimental_setup_workflow()
#   - demonstrate_dynamic_transform_discovery_workflow()  
#   - demonstrate_multi_level_validation_complete()
