        print(f"\n{module}:")
        for task in tasks:
            print(f"  {task}")
    
    # Calculate completion percentage
    total_tasks = sum(len(tasks) for tasks in checklist.values())
    completed_tasks = sum(
        1 for tasks in checklist.values() 
        for task in tasks 
        if task.startswith("✅")
    )
    completion_pct = (completed_tasks / total_tasks * 100) if total_tasks > 0 else 0
    
    print()
    print("-" * 80)
    print(f"Completion: {completed_tasks}/{total_tasks} tasks ({completion_pct:.1f}%)")
    print("-" * 80)
    
