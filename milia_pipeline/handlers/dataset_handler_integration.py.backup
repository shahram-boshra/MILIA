import logging
from typing import Dict, List, Any, Optional, Tuple

from torch_geometric.data import Data

from milia_pipeline.config.config_containers import (
    DatasetConfig, 
    FilterConfig, 
    ProcessingConfig
)
from milia_pipeline.handlers import (
    create_dataset_handler, 
    DatasetHandler
)
from milia_pipeline.exceptions import (
    MoleculeProcessingError, 
    PropertyEnrichmentError
)

# Transform System Imports
from milia_pipeline.transformations.graph_transforms import (
    TransformRegistry, 
    TransformValidator, 
    TransformComposer,
    DynamicTransformDiscovery, 
    ConfigurationBridge,
    SemanticValidator,
    DatasetAwareValidator,
    ValidationReporter,
    IntelligentCacheManager
)




logger = logging.getLogger(__name__)


# ============================================================================
# PHASE 7: Registry Integration for Dynamic Dataset Feature Queries
# ============================================================================
#
# This section adds lazy initialization infrastructure for registry imports,
# following the exact pattern from Phase 6 dataset_handlers.py.
#
# The datasets/__init__.py imports implementations which may import modules
# that this module depends on. By deferring the registry import until first use,
# we allow all modules to fully load first without circular dependency issues.
# ============================================================================

# Registry availability flags - set during lazy initialization
_REGISTRY_INITIALIZED = False
_REGISTRY_AVAILABLE = False
_REGISTRY_IMPORT_ERROR = None

# Registry function placeholders (populated by _init_registry)
_registry_list_all = None
_registry_get = None
_registry_is_registered = None


def _init_registry() -> bool:
    """
    Lazily initialize registry imports to avoid circular import at module load time.
    
    The datasets/__init__.py imports implementations which may import modules
    that this module depends on. By deferring the registry import until first use,
    we allow all modules to fully load first.
    
    Returns:
        True if registry is available, False otherwise
        
    ADDED Phase 7: Lazy initialization following Phase 3/6 pattern.
    """
    global _REGISTRY_INITIALIZED, _REGISTRY_AVAILABLE, _REGISTRY_IMPORT_ERROR
    global _registry_list_all, _registry_get, _registry_is_registered
    
    if _REGISTRY_INITIALIZED:
        return _REGISTRY_AVAILABLE
    
    _REGISTRY_INITIALIZED = True
    
    try:
        from milia_pipeline.datasets.registry import (
            list_all,
            get,
            is_registered,
        )
        
        _registry_list_all = list_all
        _registry_get = get
        _registry_is_registered = is_registered
        _REGISTRY_AVAILABLE = True
        return True
        
    except ImportError as e:
        _REGISTRY_IMPORT_ERROR = str(e)
        _REGISTRY_AVAILABLE = False
        return False


def _get_available_dataset_types() -> List[str]:
    """
    Get list of available dataset types.
    
    PHASE 7: Returns dynamic list from registry if available,
    otherwise returns legacy hardcoded list.
    
    Returns:
        List of dataset type names (e.g., ['DFT', 'DMC', 'Wavefunction'])
    """
    _init_registry()
    
    if _REGISTRY_AVAILABLE and _registry_list_all is not None:
        return _registry_list_all()
    
    # Legacy fallback
    return ['DFT', 'DMC', 'Wavefunction', 'QM9']


def _is_dataset_type_registered(dataset_type: str) -> bool:
    """
    Check if a dataset type is registered.
    
    PHASE 7: Uses registry if available, otherwise checks legacy list.
    
    Args:
        dataset_type: Dataset type name to check
        
    Returns:
        True if dataset type is registered/valid
    """
    _init_registry()
    
    if _REGISTRY_AVAILABLE and _registry_is_registered is not None:
        return _registry_is_registered(dataset_type)
    
    # Legacy fallback
    return dataset_type in ['DFT', 'DMC', 'Wavefunction', 'QM9']


def _get_dataset_feature(dataset_type: str, feature_name: str, default: bool = False) -> bool:
    """
    Get a feature flag for a dataset type from the registry.
    
    PHASE 7: Queries dataset class features via registry. Falls back to
    legacy hardcoded feature mapping if registry unavailable.
    
    Args:
        dataset_type: Dataset type name (e.g., 'DFT', 'DMC')
        feature_name: Feature to query (e.g., 'uncertainty_handling', 'vibrational_analysis')
        default: Default value if feature not found
        
    Returns:
        Boolean indicating if feature is enabled for this dataset type
        
    Examples:
        >>> _get_dataset_feature('DMC', 'uncertainty_handling')
        True
        >>> _get_dataset_feature('DFT', 'vibrational_analysis')
        True
        >>> _get_dataset_feature('Wavefunction', 'orbital_analysis')
        True
    """
    _init_registry()
    
    if _REGISTRY_AVAILABLE and _registry_get is not None:
        try:
            dataset_class = _registry_get(dataset_type)
            if hasattr(dataset_class, 'features'):
                features = dataset_class.features
                if hasattr(features, feature_name):
                    return getattr(features, feature_name)
                # Check if features is a dict-like object
                if hasattr(features, 'get'):
                    return features.get(feature_name, default)
                # Check if features has to_dict method
                if hasattr(features, 'to_dict'):
                    return features.to_dict().get(feature_name, default)
            return default
        except Exception:
            pass  # Fall through to legacy
    
    # Legacy fallback - hardcoded feature mapping
    _LEGACY_FEATURES = {
        'DFT': {
            'vibrational_analysis': True,
            'uncertainty_handling': False,
            'atomization_energy': True,
            'rotational_constants': True,
            'frequency_analysis': True,
            'orbital_analysis': False,
            'trajectory_analysis': False,
        },
        'DMC': {
            'vibrational_analysis': False,
            'uncertainty_handling': True,
            'atomization_energy': False,
            'rotational_constants': False,
            'frequency_analysis': False,
            'orbital_analysis': False,
            'trajectory_analysis': False,
        },
        'Wavefunction': {
            'vibrational_analysis': False,
            'uncertainty_handling': False,
            'atomization_energy': False,
            'rotational_constants': False,
            'frequency_analysis': False,
            'orbital_analysis': True,
            'homo_lumo_gap': True,
            'mo_energies': True,
            'trajectory_analysis': False,
        },
        'QM9': {
            'vibrational_analysis': True,
            'uncertainty_handling': False,
            'atomization_energy': True,
            'rotational_constants': True,
            'frequency_analysis': True,
            'orbital_analysis': False,
            'homo_lumo_gap': True,
            'mo_energies': False,
            'trajectory_analysis': False,
        },
    }
    
    if dataset_type in _LEGACY_FEATURES:
        return _LEGACY_FEATURES[dataset_type].get(feature_name, default)
    
    return default


def _get_dataset_transform_requirements(dataset_type: str) -> Dict[str, Any]:
    """
    Get transform requirements for a dataset type.
    
    PHASE 7: Derives requirements from dataset features.
    
    Args:
        dataset_type: Dataset type name
        
    Returns:
        Dict with keys like 'preserve_coordinates', 'preserve_metadata', etc.
    """
    requirements = {
        'preserve_coordinates': False,
        'preserve_metadata': False,
        'preserve_trajectories': False,
        'allow_augmentation': True,
    }
    
    # Derive requirements from features
    if _get_dataset_feature(dataset_type, 'vibrational_analysis'):
        requirements['preserve_coordinates'] = True
        requirements['allow_augmentation'] = False
    
    if _get_dataset_feature(dataset_type, 'uncertainty_handling'):
        requirements['preserve_metadata'] = True
    
    if _get_dataset_feature(dataset_type, 'trajectory_analysis'):
        requirements['preserve_trajectories'] = True
        requirements['allow_augmentation'] = False
    
    return requirements


def get_registry_integration_status() -> Dict[str, Any]:
    """
    Get status of registry integration for diagnostics.
    
    PHASE 7: Provides diagnostic information about registry availability.
    
    Returns:
        Dict with registry status information
    """
    _init_registry()
    
    return {
        'registry_initialized': _REGISTRY_INITIALIZED,
        'registry_available': _REGISTRY_AVAILABLE,
        'registry_import_error': _REGISTRY_IMPORT_ERROR,
        'available_dataset_types': _get_available_dataset_types(),
        'phase_7_complete': True,
    }


# =============================================================================
# TRANSFORM INTEGRATION PATTERNS
# =============================================================================

class TransformAwareHandlerIntegrator:
    """
    Enhanced integrator demonstrating handler-transform integration patterns.
    
    This class shows how to use dataset handlers in conjunction 
    with the fully-implemented transformation framework for systematic 
    experimentation.
    
    Key Features Demonstrated:
    - Dynamic transform discovery with version compatibility
    - Experimental setup loading with validation
    - Multi-level validation (basic → semantic → dataset-aware)
    - Transform caching with intelligent cache management
    - Handler-transform compatibility checking
    - Configuration migration support
    
    PHASE 7 ENHANCEMENTS:
    - Registry-based dataset feature queries
    - Feature-based transform compatibility validation
    - Dynamic dataset type support
    - Registry status diagnostics
    """
    
    def __init__(self,
                 dataset_config: DatasetConfig,
                 filter_config: FilterConfig,
                 processing_config: ProcessingConfig,
                 logger: logging.Logger,
                 experimental_setup: Optional[str] = None,
                 enable_caching: bool = True):
        """
        Initialize integrator with handler and optional experimental setup.
        
        Args:
            dataset_config: Dataset configuration
            filter_config: Filter configuration
            processing_config: Processing configuration
            logger: Logger instance
            experimental_setup: Name of experimental setup to use
            enable_caching: Enable transform composition caching
        """
        # Create dataset handler
        self.handler = create_dataset_handler(
            dataset_config, filter_config, processing_config, logger
        )
        self.logger = logger
        
        # Initialize Transform components
        # ⚠️ CRITICAL: Check which components take logger parameters
        self.transform_registry = TransformRegistry()  # NO logger
        self.transform_discovery = DynamicTransformDiscovery()  # NO logger
        self.transform_validator = TransformValidator(self.transform_registry, logger)  # Takes logger
        self.semantic_validator = SemanticValidator(self.transform_validator)  # NO logger 
        self.dataset_validator = DatasetAwareValidator(self.semantic_validator)  # NO logger
        self.transform_composer = TransformComposer(
            self.transform_registry, self.transform_validator, logger
        )
        self.config_bridge = ConfigurationBridge(self.transform_registry)
        self.validation_reporter = ValidationReporter()
        
        # Initialize intelligent caching if enabled
        self.cache_manager = None
        if enable_caching:
            self.cache_manager = IntelligentCacheManager(
                max_memory_mb=50,
                max_age_seconds=300,
                logger=logger
            )
        
        # Load experimental setup if specified
        self.experimental_setup = experimental_setup
        self.transforms = None
        self.validation_results = None
        
        if experimental_setup:
            self._load_and_validate_experimental_setup(experimental_setup)

    
    def _load_and_validate_experimental_setup(self, setup_name: str) -> None:
        """
        Load transforms from experimental setup with comprehensive validation.
        
        PATTERN: Complete workflow from loading → validation → caching.
        
        Example config.yaml:
        ```yaml
        transformations:
          experimental_setups:
            baseline:
              - name: "AddSelfLoops"
              - name: "NormalizeFeatures"
            
            with_pe:
              - name: "AddSelfLoops"
              - name: "AddLaplacianEigenvectorPE"
                params: 
                  k: 8
                  is_undirected: true
              - name: "NormalizeFeatures"
            
            augmented:
              - name: "AddSelfLoops"
              - name: "RandomRotate"
                params: 
                  degrees: 180
                  axis: 2
              - name: "NormalizeFeatures"
        ```
        """
        try:
            # Load transforms using ConfigurationBridge
            self.logger.info(f"Loading experimental setup: '{setup_name}'")
            self.transforms = self.config_bridge.load_transforms_from_config(
                experimental_setup=setup_name
            )
            
            if not self.transforms:
                self.logger.warning(f"No transforms loaded from setup '{setup_name}'")
                return
            
            self.logger.info(
                f"Loaded {len(self.transforms)} transforms from setup '{setup_name}'"
            )
            
            # Multi-level validation
            self.validation_results = self._perform_multi_level_validation()
            
            # Log validation summary
            self._log_validation_summary()
            
        except Exception as e:
            self.logger.error(f"Failed to load experimental setup '{setup_name}': {e}")
            raise
    
    def _perform_multi_level_validation(self) -> Dict[str, Any]:
        """
        Perform comprehensive multi-level validation on loaded transforms.
        
        PATTERN: Layered validation from basic to production-ready.
        
        Validation Levels:
        1. Basic: Parameter types, ranges, required fields
        2. Semantic: Transform ordering, conflicts, anti-patterns
        3. Dataset-Aware: Compatibility with DFT/DMC/MD requirements
        4. Production: Performance, safety, resource usage
        """
        validation_results = {
            'basic': {'passed': True, 'issues': []},
            'semantic': {'passed': True, 'issues': []},
            'dataset_aware': {'passed': True, 'issues': []},
            'overall_passed': True
        }
        
        if not self.transforms:
            return validation_results
        
        dataset_type = self.handler.get_dataset_type()
        
        # Level 1: Basic validation (already done by ConfigurationBridge)
        self.logger.debug("Basic validation: ✓ (performed during loading)")
        
        # Level 2: Semantic validation
        try:
            semantic_issues = self.semantic_validator.validate_transform_sequence(
                self.transforms
            )
            if semantic_issues:
                validation_results['semantic']['passed'] = False
                validation_results['semantic']['issues'] = semantic_issues
                validation_results['overall_passed'] = False
                self.logger.warning(f"Semantic validation issues: {len(semantic_issues)}")
        except Exception as e:
            self.logger.error(f"Semantic validation error: {e}")
            validation_results['semantic']['passed'] = False
            validation_results['overall_passed'] = False
        
        # Level 3: Dataset-aware validation
        try:
            dataset_issues = self.dataset_validator.validate_for_dataset_type(
                self.transforms,
                dataset_type=dataset_type
            )
            if dataset_issues:
                validation_results['dataset_aware']['passed'] = False
                validation_results['dataset_aware']['issues'] = dataset_issues
                # Don't fail overall - these are warnings
                self.logger.warning(
                    f"Dataset-aware validation issues: {len(dataset_issues)}"
                )
        except Exception as e:
            self.logger.error(f"Dataset-aware validation error: {e}")
            validation_results['dataset_aware']['passed'] = False
        
        return validation_results
    
    def _log_validation_summary(self) -> None:
        """Log comprehensive validation summary."""
        if not self.validation_results:
            return
        
        self.logger.info("=" * 60)
        self.logger.info("VALIDATION SUMMARY")
        self.logger.info("=" * 60)
        
        for level, results in self.validation_results.items():
            if level == 'overall_passed':
                continue
            
            status = "✓ PASS" if results['passed'] else "✗ FAIL"
            self.logger.info(f"{level.upper()}: {status}")
            
            if results.get('issues'):
                for issue in results['issues'][:3]:  # Show first 3 issues
                    self.logger.info(f"  - {issue}")
                if len(results['issues']) > 3:
                    self.logger.info(f"  ... and {len(results['issues']) - 3} more")
        
        overall = "✓ PASSED" if self.validation_results['overall_passed'] else "⚠ WITH WARNINGS"
        self.logger.info(f"\nOVERALL: {overall}")
        self.logger.info("=" * 60)
    
    def validate_handler_transform_compatibility(self,
                                                pyg_data: Data,
                                                raw_properties: Dict[str, Any]) -> List[str]:
        """
        Validate that transforms are compatible with dataset handler requirements.
        
        PHASE 7 REFACTORED: Uses feature-based queries instead of hardcoded
        dataset type checks. This allows automatic support for new dataset types
        that define appropriate features.
        
        Dataset-aware validation ensures transforms work with specific dataset
        features (uncertainty handling, vibrational analysis, etc.) and 
        preserve critical metadata.
        
        Example validation checks:
        - uncertainty_handling: Ensure transforms preserve uncertainty metadata (std fields)
        - vibrational_analysis: Ensure transforms maintain vibrational mode structure
        - trajectory_analysis: Ensure transforms preserve trajectory information
        - orbital_analysis: Ensure transforms preserve orbital-related data
        - All: Verify transforms don't corrupt required properties
        
        Returns:
            List of warning messages (empty if fully compatible)
        """
        warnings = []
        
        if not self.transforms:
            return warnings
        
        dataset_type = self.handler.get_dataset_type()
        
        # PHASE 7: Feature-based transform compatibility checking
        # Check uncertainty handling requirements (DMC, QMC, and future uncertainty-enabled datasets)
        if _get_dataset_feature(dataset_type, 'uncertainty_handling'):
            if hasattr(pyg_data, 'std') or 'std' in raw_properties:
                for transform in self.transforms:
                    if not self._preserves_uncertainty(transform):
                        warnings.append(
                            f"Transform {transform.__class__.__name__} may not "
                            f"preserve {dataset_type} uncertainty metadata (std fields)"
                        )
        
        # Check vibrational analysis requirements (DFT and future vibrational datasets)
        if _get_dataset_feature(dataset_type, 'vibrational_analysis'):
            if 'freqs' in raw_properties or 'vibmodes' in raw_properties:
                for transform in self.transforms:
                    if self._modifies_coordinates(transform):
                        warnings.append(
                            f"Transform {transform.__class__.__name__} modifies "
                            f"3D coordinates - {dataset_type} vibrational modes may become invalid. "
                            f"Consider recomputing modes after transformation."
                        )
        
        # Check trajectory analysis requirements (MD and future trajectory datasets)
        if _get_dataset_feature(dataset_type, 'trajectory_analysis'):
            if 'trajectory' in raw_properties:
                for transform in self.transforms:
                    if self._modifies_coordinates(transform):
                        warnings.append(
                            f"Transform {transform.__class__.__name__} modifies "
                            f"coordinates - {dataset_type} trajectory consistency may be affected"
                        )
        
        # Check orbital analysis requirements (Wavefunction and future orbital datasets)
        if _get_dataset_feature(dataset_type, 'orbital_analysis'):
            orbital_props = ['mo_energies', 'mo_occupations', 'homo_lumo_gap_eV']
            has_orbital_data = any(prop in raw_properties for prop in orbital_props)
            if has_orbital_data:
                for transform in self.transforms:
                    if self._modifies_coordinates(transform):
                        warnings.append(
                            f"Transform {transform.__class__.__name__} modifies "
                            f"coordinates - {dataset_type} orbital data may need recalculation"
                        )
        
        return warnings
    
    def _preserves_uncertainty(self, transform) -> bool:
        """
        Check if transform preserves uncertainty metadata.
        
        PHASE 7: Used by feature-based validation for datasets with
        'uncertainty_handling' feature enabled (e.g., DMC, QMC).
        
        Safe transforms only modify node/edge features without affecting
        property metadata or coordinate systems.
        
        Returns:
            True if transform is safe for uncertainty-enabled datasets
        """
        safe_transforms = {
            'AddSelfLoops', 'NormalizeFeatures', 'OneHotDegree',
            'LocalDegreeProfile', 'AddLaplacianEigenvectorPE',
            'ToUndirected', 'RemoveDuplicatedEdges', 'RemoveIsolatedNodes'
        }
        return transform.__class__.__name__ in safe_transforms
    
    def _modifies_coordinates(self, transform) -> bool:
        """
        Check if transform modifies 3D coordinates.
        
        PHASE 7: Used by feature-based validation for datasets with
        coordinate-sensitive features like 'vibrational_analysis',
        'trajectory_analysis', or 'orbital_analysis'.
        
        Coordinate-modifying transforms can invalidate precomputed
        vibrational modes, MD trajectories, or orbital calculations.
        
        Returns:
            True if transform modifies coordinates
        """
        coordinate_modifying = {
            'RandomRotate', 'RandomTranslate', 'RandomScale',
            'RandomShear', 'RandomFlip', 'Center', 'NormalizeScale',
            'RandomJitter', 'Compose'  # Compose might contain coordinate transforms
        }
        return transform.__class__.__name__ in coordinate_modifying
    
    def get_validation_report(self, format: str = 'text') -> str:
        """
        Generate comprehensive validation report.
        
        FEATURE: Use ValidationReporter for formatted output.
        
        Args:
            format: Report format ('text', 'json', or 'markdown')
            
        Returns:
            Formatted validation report
        """
        if not self.validation_results:
            return "No validation results available."
        
        return self.validation_reporter.generate_report(
            self.validation_results,
            format=format
        )
    
    def get_cache_statistics(self) -> Optional[Dict[str, Any]]:
        """
        Get cache performance statistics.
        
        FEATURE: Monitor cache effectiveness.
        
        Returns:
            Cache statistics or None if caching disabled
        """
        if not self.cache_manager:
            return None
        
        return self.cache_manager.get_statistics()
    
    def get_registry_status(self) -> Dict[str, Any]:
        """
        Get registry integration status for diagnostics.
        
        PHASE 7: Provides information about registry availability and
        current dataset type support.
        
        Returns:
            Dict with registry status information including:
            - registry_available: Whether registry is accessible
            - available_dataset_types: List of registered dataset types
            - current_dataset_type: This integrator's dataset type
            - current_dataset_features: Features enabled for current dataset
        """
        dataset_type = self.handler.get_dataset_type()
        
        # Gather features for current dataset
        feature_names = [
            'uncertainty_handling', 'vibrational_analysis', 'trajectory_analysis',
            'orbital_analysis', 'atomization_energy', 'rotational_constants',
            'frequency_analysis', 'homo_lumo_gap', 'mo_energies'
        ]
        current_features = {
            name: _get_dataset_feature(dataset_type, name)
            for name in feature_names
        }
        
        return {
            'registry_available': _REGISTRY_AVAILABLE,
            'registry_initialized': _REGISTRY_INITIALIZED,
            'available_dataset_types': _get_available_dataset_types(),
            'current_dataset_type': dataset_type,
            'current_dataset_features': current_features,
            'transform_requirements': _get_dataset_transform_requirements(dataset_type),
            'phase_7_integration': True,
        }

