        test_results['passed'].append("TransformAwareHandlerIntegrator initialization")
    except Exception as e:
        print(f"  ❌ Initialization failed: {e}")
        test_results['failed'].append(f"TransformAwareHandlerIntegrator: {e}")
        exit_code = 1
    
    # TEST 3: Transform Registry
