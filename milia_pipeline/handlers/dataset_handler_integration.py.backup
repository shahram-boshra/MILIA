#   - generate_phase2_benefits()
#   - create_phase2_performance_guide()
#   - demonstrate_phase2_testing_patterns()
#
# Documentation:
#   - generate_quick_reference_guide()
#
# CLI Interface:
#   - run_example_from_cli()
#
# =============================================================================


def run_example_from_cli():
    """
    CLI interface for running examples.
    
    Usage:
        python dataset_handler_integration.py --example <example_name>
        python dataset_handler_integration.py --quick-ref
        python dataset_handler_integration.py --list-examples
    """
    import sys
    import argparse
    
    parser = argparse.ArgumentParser(
        description="Dataset Handler Integration Examples"
    )
    parser.add_argument(
            '--example',
            choices=[
                'experimental_setup',
                'dynamic_discovery',
                'multi_level_validation',
                'error_handling',         
                'config_migration',
                'complete_workflow'
            ],
            help='Run a specific example'
        )
    parser.add_argument(
        '--quick-ref',
        action='store_true',
        help='Display quick reference guide'
    )
    parser.add_argument(
        '--list-examples',
        action='store_true',
        help='List all available examples'
    )
    
    args = parser.parse_args()
    
    if args.quick_ref:
        print(generate_quick_reference_guide())
        return
#---    
    if args.list_examples:
        print("\n📚 Available Examples:\n")
        examples = {
            'experimental_setup': demonstrate_experimental_setup_workflow,
            'dynamic_discovery': demonstrate_dynamic_transform_discovery_workflow,
            'multi_level_validation': demonstrate_multi_level_validation_complete,
            'error_handling': demonstrate_transform_error_handling,  
            'config_migration': demonstrate_config_migration_complete,
            'complete_workflow': demonstrate_complete_phase2_workflow
        }
        
        for name, func in examples.items():
            print(f"  • {name}")
            # Extract first meaningful line from docstring
            docstring_lines = func.__doc__.split('\n')
            if len(docstring_lines) > 1:
                print(f"    {docstring_lines[1].strip()}")
            print()
        
        print("Usage: python dataset_handler_integration.py --example <example_name>\n")
        return
    
    if args.example:
        examples_map = {
            'experimental_setup': demonstrate_experimental_setup_workflow,
            'dynamic_discovery': demonstrate_dynamic_transform_discovery_workflow,
            'multi_level_validation': demonstrate_multi_level_validation_complete,
            'error_handling': demonstrate_transform_error_handling,  
            'config_migration': demonstrate_config_migration_complete,
            'complete_workflow': demonstrate_complete_phase2_workflow
        }
#---        
        func = examples_map[args.example]
        separator = '=' * 80
        print(f"\n{separator}")
        print(f"EXAMPLE: {args.example}")
        print(f"{'=' * 80}\n")
        print(func())
        print(f"\n{separator}\n")
    else:
        parser.print_help()

#---
if __name__ == "__main__":
    import sys
    from pathlib import Path
    
    # Check if running with arguments (CLI mode)
    if len(sys.argv) > 1:
        run_example_from_cli()
        sys.exit(0)
    
