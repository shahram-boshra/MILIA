# config.yaml - Enhanced Structural Features Support with DMC Integration
# Added prediction configuration for post-training inference


# ────────────
# Global Paths
# ────────────
global_paths:
  working_root_dir: ~/Chem_Data/Milia_PyG_Dataset

# ────────────
# Dataset Type      
# ────────────
dataset_type: "DFT"  # Options: "DFT", "DMC", "Wavefunction", "QM9", "ANI1X", "ANI1CCX", "RMD17", "ANI2X", "XXMD", "QDPi"

# ─────────────────────────
# DFT Dataset Configuration
# ─────────────────────────
dft_config:
  # Filename for the raw .npz dataset file
  raw_npz_filename: DFT_all_sliced.npz   
  # URL to download the raw dataset file (can be .npz, .tar.gz, .zip, etc.)
  raw_data_download_url: https://zenodo.org/records/15442257/files/DFT_all.npz?download=1

# ─────────────────────────
# DMC Dataset Configuration
# ─────────────────────────
dmc_config:
  # DMC dataset filename and URL
  raw_npz_filename: DMC.npz
  # URL to download the raw dataset file (can be .npz, .tar.gz, .zip, etc.)
  raw_data_download_url: https://zenodo.org/records/15442257/files/DMC.npz?download=1
  
  # DMC uncertainty handling
  uncertainty_handling:
    # Field name containing uncertainties (typically 'std')
    uncertainty_field_name: std
    # Use uncertainties for loss weighting during training
    use_for_loss_weighting: true
    # Filter molecules with uncertainty above threshold
    max_uncertainty_threshold: null # null or e.g., 0.1 to filter high-uncertainty molecules
    # Uncertainty weighting strategy
    uncertainty_weighting: "inverse_variance"  # Options: "inverse_variance", "uniform"

# ──────────────────────────────────
# Wavefunction Dataset Configuration
# ──────────────────────────────────
wavefunction_config:
  # Filename for the preprocessed .npz wavefunction dataset file
  raw_npz_filename: wavefunctions.npz
  # URL to download raw wavefunction data (optional - typically preprocessed locally)
  raw_data_download_url: https://zenodo.org/records/15442257/files/wavefunctions.tar.gz?download=1
  # Root directory where the processed PyTorch Geometric dataset will be stored
  
  # Wavefunction processing configuration
  processing_config:
    # Feature extraction tier: "basic", "standard", or "complete"
    # - basic: Essential features (atoms, coordinates, HOMO/LUMO)
    # - standard: Basic + orbital energies, occupations  
    # - complete: Standard + full coefficient matrices, all MO data
    feature_tier: basic

    # Preprocessing parameters (for automatic tar.gz → npz conversion)
    preprocessing:
      # Number of molecules to preprocess (null = all molecules in archive)
      # Use integer for testing/limiting dataset size (e.g., 10, 100, 1000) (applies for preprocessing step)
      num_molecules: 25
      
      # Clean up temporary .molden files after preprocessing
      cleanup_temp: true
  
  # Uncertainty handling (placeholder for future implementation)
  uncertainty_handling:
    # Currently not supported for wavefunction datasets
    enabled: false

# ─────────────────────────
# QM9 Dataset Configuration
# ─────────────────────────
qm9_config:
  # Filename for the preprocessed .npz QM9 dataset file (OUTPUT after preprocessing)
  raw_npz_filename: qm9.npz
  
  # Filename for the raw source archive (INPUT before preprocessing)
  # CRITICAL: Required for URLs that don't include the filename (e.g., Figshare API URLs)
  # This is the actual filename that will be downloaded and saved locally
  raw_source_filename: dsgdb9nsd.xyz.tar.bz2
  
  # URL to download the raw QM9 archive (tar.bz2 format)
  # Source: Figshare - Quantum chemistry structures and properties of 134k molecules
  # Reference: Ramakrishnan et al., Scientific Data 1, 140022 (2014)
  # NOTE: Figshare uses API-style URLs that don't contain the filename
  raw_data_download_url: https://figshare.com/ndownloader/files/3195389
  
  # QM9 processing configuration
  processing_config:
    # Preprocessing parameters (for automatic tar.bz2 → npz conversion)
    preprocessing:
      # Number of molecules to preprocess (null = all 133,885 molecules)
      # Use integer for testing/limiting dataset size (e.g., 100, 1000, 10000)
      num_molecules: null
      
      # Clean up temporary .xyz files after preprocessing
      cleanup_temp: true
  
  # QM9 does not have uncertainty handling (DFT calculations are deterministic)
  uncertainty_handling:
    enabled: false

# ──────────────────────────
# ANI-1x Dataset Configuration
# ──────────────────────────
ani1x_config:
  # Filename for the preprocessed .npz ANI-1x dataset file (OUTPUT after preprocessing)
  raw_npz_filename: ani1x.npz
  
  # Filename for the raw HDF5 source file (INPUT before preprocessing)
  # CRITICAL: Required for URLs that don't include the filename (e.g., Figshare API URLs)
  # This is the actual filename that will be downloaded and saved locally
  raw_source_filename: ani1x-release.h5
  
  # URL to download the raw ANI-1x HDF5 file
  # Source: Figshare - ANI-1x and ANI-1ccx datasets
  # Reference: Smith et al., Scientific Data 7, 134 (2020)
  # DOI: 10.1038/s41597-020-0473-z
  # NOTE: Figshare uses API-style URLs that don't contain the filename
  raw_data_download_url: https://figshare.com/ndownloader/files/18112775
  
  # ANI-1x processing configuration
  processing_config:
    # Preprocessing parameters (for automatic HDF5 → npz conversion)
    preprocessing:
      # Number of conformers to preprocess (null = all ~5 million conformers)
      # Use integer for testing/limiting dataset size (e.g., 1000, 10000, 100000)
      num_molecules: 50
      
      # Property keys to extract from HDF5 file
      # Available: wb97x_dz.energy, wb97x_dz.forces, wb97x_dz.hirshfeld_charges,
      #            wb97x_dz.cm5_charges, wb97x_dz.dipole
      property_keys:
        - wb97x_dz.energy
        - wb97x_dz.forces
        - wb97x_dz.hirshfeld_charges
        - wb97x_dz.cm5_charges
        - wb97x_dz.dipole
  
  # ANI-1x does not have uncertainty handling (DFT calculations are deterministic)
  uncertainty_handling:
    enabled: false

# ──────────────────────────────
# ANI-1ccx Dataset Configuration
# ──────────────────────────────
ani1ccx_config:
  # Filename for the preprocessed .npz ANI-1ccx dataset file (OUTPUT after preprocessing)
  raw_npz_filename: ani1ccx.npz
  
  # Filename for the raw HDF5 source file (INPUT before preprocessing)
  # CRITICAL: Same file as ANI-1x - both datasets are in ani1x-release.h5
  # ANI-1ccx is the ~500k conformer subset with coupled-cluster energies
  raw_source_filename: ani1x-release.h5
  
  # URL to download the raw HDF5 file (SAME as ANI-1x)
  # Source: Figshare - ANI-1x and ANI-1ccx datasets
  # Reference: Smith et al., Scientific Data 7, 134 (2020)
  # DOI: 10.1038/s41597-020-0473-z
  raw_data_download_url: https://figshare.com/ndownloader/files/18112775
  
  # ANI-1ccx processing configuration
  processing_config:
    # Preprocessing parameters (for automatic HDF5 → npz conversion)
    preprocessing:
      # Number of conformers to preprocess (null = all ~500k CC conformers)
      # Use integer for testing/limiting dataset size (e.g., 1000, 10000, 100000)
      num_molecules: 50
      
      # Property keys to extract from HDF5 file
      # CRITICAL: ccsd(t)_cbs.energy MUST be included - it filters to ANI-1ccx subset
      # Available: ccsd(t)_cbs.energy, wb97x_dz.energy, wb97x_dz.forces,
      #            wb97x_dz.hirshfeld_charges, wb97x_dz.cm5_charges, wb97x_dz.dipole
      property_keys:
        - ccsd(t)_cbs.energy      # REQUIRED - coupled-cluster energy (primary target)
        - wb97x_dz.energy         # DFT energy for comparison
        - wb97x_dz.forces
        - wb97x_dz.hirshfeld_charges
        - wb97x_dz.cm5_charges
        - wb97x_dz.dipole
  
  # ANI-1ccx does not have uncertainty handling (CC calculations are deterministic)
  uncertainty_handling:
    enabled: false

# ──────────────────────────
# rMD17 Dataset Configuration
# ──────────────────────────
rmd17_config:
  # Filename for the preprocessed .npz rMD17 dataset file (OUTPUT after preprocessing)
  raw_npz_filename: rmd17.npz
  
  # Filename for the raw archive file (INPUT before preprocessing)
  # rMD17 is distributed as a tar.bz2 archive containing 10 NPZ files (one per molecule)
  raw_source_filename: rmd17.tar.bz2
  
  # URL to download the raw rMD17 archive
  # Source: Materials Cloud Archive (DOI: 10.24435/materialscloud:wy-kn)
  # Reference: Christensen & von Lilienfeld, Mach. Learn.: Sci. Technol. 1, 045018 (2020)
  # DOI: 10.1088/2632-2153/abba6f | arXiv: 2007.09593
  #
  # NOTE: This is a ~1GB file. Download may timeout with default settings.
  # The download redirects to rgw.cscs.ch (CSCS Swiss storage server).
  # If timeout errors occur, either:
  #   1. Increase download timeout in the pipeline (recommended: 600+ seconds)
  #   2. Manually download and place rmd17.tar.bz2 in the raw/ directory
  #
  # Alternative source (Figshare): https://figshare.com/ndownloader/articles/12672038/versions/3
  # Note: Figshare returns a .zip file, not .tar.bz2, requiring preprocessor modification
  raw_data_download_url: https://archive.materialscloud.org/records/pfffs-fff86/files/rmd17.tar.bz2?download=1
  
  # rMD17 processing configuration
  processing_config:
    # Preprocessing parameters (for automatic tar.bz2 → unified npz conversion)
    #
    # NOTE: rMD17 structure differs from ANI-1x/ANI-1ccx
    # ─────────────────────────────────────────────────────
    # rMD17 contains 10 separate molecule files (aspirin, benzene, etc.),
    # each with ~100k conformers. Unlike ANI-1x which uses 'num_molecules' 
    # for total conformers, rMD17 uses two parameters:
    #   - molecules_to_include: which molecule types to process
    #   - max_conformers_per_molecule: conformers per molecule type
    #
    # For testing: set max_conformers_per_molecule=10 → 10×10=100 total conformers
    #
    preprocessing:
      # Molecules to include (null = all 10 molecules)
      # Available: aspirin, azobenzene, benzene, ethanol, malonaldehyde,
      #            naphthalene, paracetamol, salicylic, toluene, uracil
      molecules_to_include: null
      
      # Maximum conformers per molecule (null = all ~100k per molecule)
      # Use integer for testing/limiting dataset size (e.g., 100, 1000, 10000)
      # CRITICAL WARNING: DO NOT train on >1000 samples due to autocorrelation
      max_conformers_per_molecule: 5
      
      # Whether to include old MD17 data (old_energies, old_forces, old_indices)
      # for comparison with original noisy dataset
      include_old_data: false
      
      # Whether to clean up temporary extraction directory after preprocessing
      cleanup_temp: true
  
  # rMD17 does not have uncertainty handling (DFT calculations are deterministic)
  uncertainty_handling:
    enabled: false


# ──────────────────────────
# ANI-2x Dataset Configuration
# ──────────────────────────
ani2x_config:
  # Filename for the preprocessed .npz ANI-2x dataset file (OUTPUT after preprocessing)
  raw_npz_filename: ani2x.npz
  
  # Filename for the raw archive file (INPUT before preprocessing)
  # ANI-2x is distributed as a tar.gz archive containing an HDF5 file
  raw_source_filename: ANI-2x-wB97X-631Gd.tar.gz
  
  # URL to download the raw ANI-2x archive
  # Source: Zenodo (DOI: 10.5281/zenodo.10108942)
  # Reference: Devereux et al., J. Chem. Theory Comput. 2020, 16, 4192-4202
  # DOI: 10.1021/acs.jctc.0c00121
  #
  # NOTE: This is a ~3.7GB file. Download may timeout with default settings.
  # If timeout errors occur, either:
  #   1. Increase download timeout in the pipeline (recommended: 600+ seconds)
  #   2. Manually download and place ANI-2x-wB97X-631Gd.tar.gz in the raw/ directory
  raw_data_download_url: https://zenodo.org/api/records/10108942/files/ANI-2x-wB97X-631Gd.tar.gz/content
  
  # ANI-2x processing configuration
  processing_config:
    # Preprocessing parameters (for automatic tar.gz → npz conversion)
    preprocessing:
      # Number of conformers to preprocess (null = all conformers)
      # Use integer for testing/limiting dataset size (e.g., 1000, 10000, 100000)
      num_molecules: 50
      
      # Property keys to extract from HDF5 file
      # Available: energies, forces
      property_keys:
        - energies
        - forces
  
  # ANI-2x does not have uncertainty handling (DFT calculations are deterministic)
  uncertainty_handling:
    enabled: false


# ──────────────────────────────
# xxMD Dataset Configuration
# ──────────────────────────────
xxmd_config:
  # Filename for the preprocessed .npz xxMD dataset file (OUTPUT after preprocessing)
  raw_npz_filename: xxmd.npz
  
  # Filename for the raw archive file (INPUT before preprocessing)
  # xxMD is distributed as a ZIP archive containing extended XYZ files
  raw_source_filename: xxMD-main.zip
  
  # URL to download the raw xxMD archive
  # Source: Zenodo (DOI: 10.5281/zenodo.10393858)
  # Reference: Pengmei et al., Scientific Data 11, 222 (2024)
  # DOI: 10.1038/s41597-024-03019-3
  raw_data_download_url: https://zenodo.org/api/records/10393859/files/xxMD-main.zip/content
  
  # xxMD processing configuration
  processing_config:
    # Preprocessing parameters (for automatic ZIP → npz conversion)
    #
    # NOTE: xxMD structure is similar to rMD17 but with different molecules
    # ─────────────────────────────────────────────────────────────────────
    # xxMD contains trajectories for 4 photochemically active molecules.
    # Two subsets are available:
    #   - xxMD-DFT: Ground-state M06 DFT energies and forces (default)
    #   - xxMD-CASSCF: Multi-state SA-CASSCF (S0/S1/S2) - advanced use
    #
    # For testing: set max_conformers_per_molecule=100 for quick validation
    #
    preprocessing:
      # Subset to process: 'DFT' (ground state) or 'CASSCF' (multi-state)
      # CASSCF is more complex and not yet fully supported
      subset: DFT
      
      # Molecules to include (null = all 4 molecules)
      # Available: azobenzene, dithiophene, malonaldehyde, stilbene
      molecules_to_include: null
      
      # Maximum conformers per molecule (null = all conformers)
      # Use integer for testing/limiting dataset size (e.g., 100, 1000)
      max_conformers_per_molecule: 25
      
      # Whether to clean up temporary extraction directory after preprocessing
      cleanup_temp: true
  
  # xxMD does not have uncertainty handling (DFT calculations are deterministic)
  uncertainty_handling:
    enabled: false


# ────────────────────────────────────────────────────
# QDPi Configuration (Quantum Deep Potential Interaction)
# ────────────────────────────────────────────────────
# Reference: Zeng et al., Scientific Data 12, 693 (2025)
# DOI: 10.1038/s41597-025-04972-3
# Zenodo: https://zenodo.org/records/14970869
#
# Dataset contains ~1.6 million structures for drug discovery ML potentials.
# Level of theory: ωB97M-D3(BJ)/def2-TZVPPD (highly accurate functional)
# Elements: H, Li, C, N, O, F, Na, P, S, Cl, K, Br, I (13 elements)
#
# IMPORTANT: Source data is in eV - preprocessor converts to Hartree
# ────────────────────────────────────────────────────
qdpi_config:
  # Filename for the preprocessed .npz QDπ dataset file (OUTPUT after preprocessing)
  raw_npz_filename: qdpi.npz
  
  # Filename for the raw archive file (INPUT before preprocessing)
  # QDπ is distributed as a tar.gz archive containing DeePMD-kit HDF5 files
  raw_source_filename: QDpiDataset-main.tar.gz
  
  # URL to download the raw QDπ archive
  # Source: Zenodo (DOI: 10.5281/zenodo.14970869)
  # Reference: Zeng et al., Scientific Data 12, 693 (2025)
  # DOI: 10.1038/s41597-025-04972-3
  raw_data_download_url: https://zenodo.org/api/records/14970869/files/QDpiDataset-main.tar.gz/content
  
  # QDπ processing configuration
  processing_config:
    # Preprocessing parameters (for automatic tar.gz → npz conversion)
    #
    # NOTE: QDπ uses DeePMD-kit HDF5 format organized by chemical formula
    # ─────────────────────────────────────────────────────────────────────
    # QDπ contains ~1.6 million structures from diverse sources:
    #   - SPICE, ANI, GEOM, FreeSolv, RE, COMP6 datasets
    # Structures selected via query-by-committee active learning
    #
    # UNIT CONVERSIONS APPLIED:
    #   - Energy: eV → Hartree (1 Ha = 27.211386245988 eV)
    #   - Forces: eV/Å → Hartree/Å
    #   - Coordinates: Angstrom (no conversion)
    #
    # For testing: set num_molecules=10000 for quick validation
    #
    preprocessing:
      # Maximum conformers to extract (null = all ~1.6 million)
      # Use integer for testing/limiting dataset size (e.g., 10000)
      num_molecules: 50
      
      # Properties to extract from HDF5
      # Available: energy, force
      property_keys:
        - energy
        - force
      
      # Whether to clean up temporary extraction directory after preprocessing
      cleanup_temp: true
  
  # QDπ does not have uncertainty handling (DFT calculations are deterministic)
  uncertainty_handling:
    enabled: false


# ────────────────
# Global_Constants
# ────────────────
global_constants:
  har2ev: 27.211386245988
  bohr_to_angstrom: 0.529177210903

atomic_energies_hartree:
  # Atomic energies in Hartree for common heavy atoms (and Hydrogen)
  1: -0.5012728848846926  # H
  6: -37.83859584856468    # C
  7: -54.5760607136932450 # N
  8: -75.0474818911551438 # O
  9: -99.7031524437270917 # F
  17: -460.13960793480203 # Cl
  15: -341.2510291850040858 # P
  35: -2574.01253635198464 # Br
  16: -398.1021030909759020 # S
  14: -289.3578409507016431 # Si

heavy_atom_symbols_to_z:
  # Mapping from common heavy atom symbols to their atomic numbers
  C: 6
  N: 7
  O: 8
  F: 9
  Cl: 17
  P: 15
  Br: 35
  S: 16
  Si: 14

# ──────────────────────────────────────────
# ENHANCED STRUCTURAL FEATURES CONFIGURATION
# ──────────────────────────────────────────
structural_features:
  # Atom-level structural features
  atom:
    # Basic connectivity features
    - degree              # Number of directly bonded neighbors
    - total_degree        # Total degree including implicit hydrogens
    - hybridization       # One-hot encoded hybridization (sp, sp2, sp3, etc.)
    - total_valence       # Total valence of the atom
    - is_aromatic         # Boolean: atom is aromatic
    - is_in_ring          # Boolean: atom is in any ring
    
    # NEW: Advanced atom features
    #- partial_charge      # Gasteiger partial charges (fallback)
    - mulliken_charge     # VQM24 precomputed Mulliken charges (preferred)
    - num_aromatic_bonds  # Count of aromatic bonds connected to atom
    - chirality           # One-hot encoded chirality (R/S configuration)
  
  # Bond-level structural features  
  bond:
    # Basic bond features
    - bond_type           # One-hot encoded bond type (single, double, triple, aromatic)
    - is_conjugated       # Boolean: bond is conjugated
    - is_aromatic         # Boolean: bond is aromatic
    - is_in_any_ring      # Boolean: bond is in any ring
    
    # NEW: Advanced bond features
    - stereo              # One-hot encoded stereochemistry (E/Z)
    - bond_length         # 3D geometric bond length from QM-optimized coordinates
    - bond_length_binned  # Discretized bond lengths for categorical learning
  
  # Feature preprocessing settings
  preprocessing:
    # For partial_charge and mulliken_charge features
    charge_handling:
      # Prefer Mulliken charges from VQM24 over computed Gasteiger charges
      prefer_mulliken: true
      # Fallback to Gasteiger if Mulliken not available
      compute_gasteiger_fallback: true
      # Handle missing charges
      missing_charge_default: 0.0
    
    # For 3D geometric features (bond_length, bond_length_binned)
    geometric_features:
      # Enable 3D features (requires conformer data)
      enable_3d_features: true
      # Conformer ID to use for 3D calculations
      conformer_id: 0
      # Default bond length for missing conformer data
      missing_length_default: 0.0
      
      # Bond length binning configuration (for bond_length_binned feature)
      bond_length_bins:
        # Bin edges in Angstroms - designed for common organic bond lengths
        bin_edges: [0.0, 1.0, 1.2, 1.4, 1.6, 1.8, 2.0, 2.5, 3.0, 999.0]
        # Bin labels for interpretability (optional)
        bin_labels: ["very_short", "short", "C-C_single", "C=C_double", "medium", "long", "very_long", "extreme", "missing"]
    
    # Stereochemistry handling
    stereochemistry:
      # Ensure stereochemistry is assigned before feature extraction
      assign_stereochemistry: true
      # Clean up stereochemistry for better consistency
      cleanup_stereochemistry: true

# ────────────────────────────────────────────────────
# Property Availability Matrix - Exact Milia .npz keys
# ────────────────────────────────────────────────────
property_availability:

# ────────────────────────────────────────────────────
# DFT Property Availability Matrix
# ────────────────────────────────────────────────────
  DFT:
    # Fundamental molecular identifiers and structure
    molecular_identifiers:
      - compounds     # Compound identifiers
      - inchi         # InChI string representation
      - graphs        # Graph representations
      - frags         # Fragment information (not in saddles)
    
    # Atomic structure properties
    atomic_structure:
      - atoms         # Atomic numbers/symbols
      - coordinates   # Cartesian coordinates (x, y, z) - QM-optimized
    
    # Scalar graph-level properties (energies and thermodynamics)
    scalar_graph_targets:
      # Core energies
      - Etot          # Total electronic energy
      - U0            # Internal energy at 0K
      - U298          # Internal energy at 298K
      - zpves         # Zero-point vibrational energy
      - gap           # HOMO-LUMO gap
      - Eatomization  # Atomization energy
      # Electronic interaction energies
      - Eee           # Electron-electron repulsion energy
      - Exc           # Exchange-correlation energy
      - Edisp         # Dispersion energy
      # Thermodynamic properties
      - H             # Enthalpy
      - S             # Entropy
      - G             # Gibbs free energy
      - Cv            # Heat capacity at constant volume
      - Cp            # Heat capacity at constant pressure
    
    # Node-level (atomic) properties
    node_features:
      - Qmulliken     # Mulliken atomic charges (for mulliken_charge feature)
      - Vesp          # Electrostatic potential at nuclei
    
    # Fixed-size vector graph properties
    vector_graph_properties:
      # Multipole moments
      - dipole        # Electric dipole moment
      - quadrupole    # Electric quadrupole moment  
      - octupole      # Electric octupole moment
      - hexadecapole  # Electric hexadecapole moment
      # Rotational properties
      - rots          # Rotational constants
    
    # Variable-length graph properties
    variable_len_graph_properties:
      - freqs         # Vibrational frequencies
      - vibmodes      # Vibrational normal modes
    
    uncertainty_fields: []  # DFT calculations don't have uncertainty fields

# ────────────────────────────────────────────────────
# DMC Property Availability Matrix
# ────────────────────────────────────────────────────  
  DMC:
    # Fundamental molecular identifiers and structure (subset available in DMC)
    molecular_identifiers:
      - compounds     # Compound identifiers
      - inchi         # InChI string representation
      - graphs        # Graph representations
    
    # Atomic structure properties (inherited from DFT optimization)
    atomic_structure:
      - atoms         # Atomic numbers/symbols
      - coordinates   # Cartesian coordinates from DFT optimization (for 3D features)
    
    # DMC focuses primarily on high-accuracy energies
    scalar_graph_targets:
      - Etot          # DMC total energy (primary target)
    
    # DMC doesn't provide detailed electronic structure
    node_features: []  # No Mulliken charges available in DMC
    vector_graph_properties: []
    variable_len_graph_properties: []
    
    # DMC-specific uncertainty information
    uncertainty_fields:
      - std           # DMC statistical uncertainty (metadata, not target)

# ────────────────────────────────────────────────────
# Wavefunction Property Availability Matrix
# ────────────────────────────────────────────────────
  Wavefunction:
    # VQM24 Wavefunction Dataset Property Availability
    # Source: .molden files parsed via IOData → wavefunctions.npz
    # Reference: VQM24 dataset (Zenodo record 15442257)
    # Coordinate units: Bohr | Energy units: Hartree
    
    # Molecular identifiers
    molecular_identifiers:
      - compounds           # Compound identifiers (e.g., NxO2PxSiH6_103)
      - molecular_formula   # Molecular formula string (e.g., PSiO2NH6)
    
    # Atomic structure properties
    atomic_structure:
      - atoms               # Atomic numbers (int64 array)
      - coordinates         # Cartesian coordinates in Bohr (float64, shape: n_atoms x 3)
      - n_atoms             # Number of atoms per molecule (int32)
    
    # Scalar graph-level properties
    scalar_graph_targets:
      # Frontier orbital energies (Hartree)
      - homo_energy                 # HOMO orbital energy
      - lumo_energy                 # LUMO orbital energy
      - homo_lumo_gap               # HOMO-LUMO gap (Hartree)
      - homo_lumo_gap_eV            # HOMO-LUMO gap (eV)
      # Occupied orbital energy statistics (Hartree)
      - occupied_energy_mean        # Mean occupied orbital energy
      - occupied_energy_std         # Std dev of occupied orbital energies
      - occupied_energy_min         # Minimum occupied orbital energy
      - occupied_energy_max         # Maximum occupied orbital energy
      # Virtual orbital energy statistics (Hartree)
      - virtual_energy_mean         # Mean virtual orbital energy
      - virtual_energy_std          # Std dev of virtual orbital energies
      - virtual_energy_min          # Minimum virtual orbital energy
      - virtual_energy_max          # Maximum virtual orbital energy
      # Chemical descriptors (Hartree, Koopmans' theorem approximations)
      - ionization_potential_approx # Ionization potential approximation
      - electron_affinity_approx    # Electron affinity approximation
      - chemical_hardness           # Chemical hardness
      - chemical_potential          # Chemical potential
      # Electronic structure counts
      - n_electrons                 # Total number of electrons (float64)
      - n_basis                     # Number of basis functions (int32)
      - n_occupied_orbitals         # Number of occupied MOs (int32)
      - n_virtual_orbitals          # Number of virtual MOs (int32)
      # Molecular properties
      - molecular_weight            # Molecular weight in amu (float64)
    
    # Node-level (atomic) properties
    node_features: []  # No per-atom features in current .molden extraction
    
    # Fixed-size vector graph properties
    vector_graph_properties: []  # No fixed-size vector properties
    
    # Variable-length graph properties (MO data)
    variable_len_graph_properties:
      - mo_energies         # All molecular orbital energies (float64, shape: n_basis)
      - mo_occupations      # All molecular orbital occupations (float64, shape: n_basis)
      - mo_coefficients     # MO coefficient matrix (float64, shape: n_basis x n_basis)
    
    # Metadata fields (non-target)
    metadata_fields:
      - mo_kind             # MO type: 'restricted' or 'unrestricted' (object/string)
    
    # Wavefunction data is deterministic - no uncertainty fields
    uncertainty_fields: []

# ────────────────────────────────────────────────────
# QM9 Property Availability Matrix
# ──────────────────────────────────────────────────── 
  QM9:
    # QM9 Dataset Property Availability (25 keys in qm9.npz)
    # Reference: Ramakrishnan et al., Scientific Data 1, 140022 (2014)
    # Contains 133,885 small organic molecules (CHONF, up to 9 heavy atoms)
    # Level of theory: B3LYP/6-31G(2df,p)
    
    # Molecular identifiers (5 keys)
    molecular_identifiers:
      - compounds       # Compound identifiers (file names: dsgdb9nsd_XXXXXX)
      - smiles          # SMILES string (original from GDB-17)
      - smiles_relaxed  # SMILES string (relaxed geometry)
      - inchi           # InChI string (original from GDB-17)
      - inchi_relaxed   # InChI string (relaxed geometry)
    
    # Atomic structure properties (2 keys)
    atomic_structure:
      - atoms           # Atomic numbers (C=6, H=1, O=8, N=7, F=9)
      - coordinates     # B3LYP/6-31G(2df,p) optimized coordinates (Angstrom)
    
    # Scalar graph-level properties (15 keys)
    # All energies in Hartree, Cv in cal/(mol·K)
    scalar_graph_targets:
      # Rotational constants (GHz) - stored as separate scalars
      - A               # Rotational constant A
      - B               # Rotational constant B
      - C               # Rotational constant C
      # Electronic properties
      - mu              # Dipole moment (Debye)
      - alpha           # Isotropic polarizability (Bohr³)
      - homo            # HOMO energy (Hartree)
      - lumo            # LUMO energy (Hartree)
      - gap             # HOMO-LUMO gap (Hartree)
      - r2              # Electronic spatial extent (Bohr²)
      # Thermodynamic properties
      - zpve            # Zero point vibrational energy (Hartree)
      - U0              # Internal energy at 0K (Hartree)
      - U               # Internal energy at 298.15K (Hartree)
      - H               # Enthalpy at 298.15K (Hartree)
      - G               # Free energy at 298.15K (Hartree)
      - Cv              # Heat capacity at 298.15K (cal/(mol·K))
    
    # Node-level (atomic) properties (1 key)
    node_features:
      - Qmulliken       # Mulliken partial charges (e)
    
    # Fixed-size vector graph properties
    vector_graph_properties: []  # A, B, C stored as separate scalars, not as vector
    
    # Variable-length graph properties (1 key)
    variable_len_graph_properties:
      - freqs           # Vibrational frequencies (cm⁻¹)
    
    # Metadata fields (1 key)
    metadata_fields:
      - metadata        # Dataset metadata (object array)
    
    # QM9 is DFT-based - no uncertainty fields
    uncertainty_fields: []

# ────────────────────────────────────────────────────
# ANI1X Property Availability Matrix
# ──────────────────────────────────────────────────── 
  ANI1X:
    # ANI-1x Dataset Property Availability (9 keys in ani1x.npz)
    # Reference: Smith et al., Scientific Data 7, 134 (2020)
    # DOI: 10.1038/s41597-020-0473-z
    # Source: HDF5 file from Figshare, preprocessed via ANI1xPreprocessor
    # Contains ~5 million DFT conformations for organic molecules (CHNO)
    # Level of theory: ωB97x/6-31G* (wb97x_dz)
    # Coordinate units: Angstrom | Energy units: Hartree | Force units: Hartree/Angstrom
    
    # Molecular identifiers (1 key)
    molecular_identifiers:
      - molecule_id     # Chemical isomer group identifier from HDF5 (object/string)
    
    # Atomic structure properties (2 keys)
    atomic_structure:
      - atoms           # Atomic symbols as strings, e.g., ['C', 'H', 'N', 'O'] (object array)
      - coordinates     # Cartesian coordinates in Angstrom (object array, shape: n_atoms x 3)
    
    # Scalar graph-level properties (1 key)
    scalar_graph_targets:
      - energy          # ωB97x/6-31G* DFT total energy (Hartree, float64)
    
    # Node-level (atomic) properties (3 keys)
    node_features:
      - forces              # Atomic forces (Hartree/Angstrom, object array, shape: n_atoms x 3)
      - hirshfeld_charges   # Hirshfeld atomic charges (e, object array, shape: n_atoms)
      - cm5_charges         # CM5 atomic charges (e, object array, shape: n_atoms)
    
    # Fixed-size vector graph properties (1 key)
    vector_graph_properties:
      - dipole          # Molecular dipole moment (Debye, object array, shape: 3)
    
    # Variable-length graph properties
    variable_len_graph_properties: []  # No variable-length properties beyond node_features
    
    # Metadata fields (1 key)
    metadata_fields:
      - _metadata       # Preprocessing metadata as string array (object)
    
    # ANI-1x is DFT-based - no uncertainty fields
    uncertainty_fields: []

# ────────────────────────────────────────────────────
# ANI1CCX Property Availability Matrix
# ──────────────────────────────────────────────────── 
  ANI1CCX:
    # ANI-1ccx Dataset Property Availability (10 keys in ani1ccx.npz)
    # Reference: Smith et al., Scientific Data 7, 134 (2020)
    # DOI: 10.1038/s41597-020-0473-z
    # Source: HDF5 file from Figshare (SAME file as ANI-1x), preprocessed via ANI1ccxPreprocessor
    # Contains ~500k coupled-cluster conformations for organic molecules (CHNO)
    # Level of theory: CCSD(T)/CBS extrapolation (primary) + ωB97x/6-31G* DFT (secondary)
    # Coordinate units: Angstrom | Energy units: Hartree | Force units: Hartree/Angstrom
    # CRITICAL: ANI-1ccx is a SUBSET of ANI-1x with coupled-cluster energies
    
    # Molecular identifiers (1 key)
    molecular_identifiers:
      - molecule_id     # Chemical isomer group identifier from HDF5 (object/string)
    
    # Atomic structure properties (2 keys)
    atomic_structure:
      - atoms           # Atomic symbols as strings, e.g., ['C', 'H', 'N', 'O'] (object array)
      - coordinates     # Cartesian coordinates in Angstrom (object array, shape: n_atoms x 3)
    
    # Scalar graph-level properties (2 keys)
    scalar_graph_targets:
      - ccsd_energy     # CCSD(T)/CBS coupled-cluster energy (Hartree, float64) - PRIMARY TARGET
      - dft_energy      # ωB97x/6-31G* DFT energy (Hartree, float64) - for comparison
    
    # Node-level (atomic) properties (3 keys)
    node_features:
      - forces              # Atomic forces from DFT (Hartree/Angstrom, object array, shape: n_atoms x 3)
      - hirshfeld_charges   # Hirshfeld atomic charges (e, object array, shape: n_atoms)
      - cm5_charges         # CM5 atomic charges (e, object array, shape: n_atoms)
    
    # Fixed-size vector graph properties (1 key)
    vector_graph_properties:
      - dipole          # Molecular dipole moment from DFT (Debye, object array, shape: 3)
    
    # Variable-length graph properties
    variable_len_graph_properties: []  # No variable-length properties beyond node_features
    
    # Metadata fields (1 key)
    metadata_fields:
      - _metadata       # Preprocessing metadata as string array (object)
    
    # ANI-1ccx is coupled-cluster based - no uncertainty fields
    uncertainty_fields: []

# ────────────────────────────────────────────────────
# rMD17 Property Availability Matrix
# ──────────────────────────────────────────────────── 
  RMD17:
    # rMD17 (Revised MD17) Dataset Property Availability (6+ keys in rmd17.npz)
    # Reference: Christensen & von Lilienfeld, Mach. Learn.: Sci. Technol. 1, 045018 (2020)
    # DOI: 10.1088/2632-2153/abba6f | arXiv: 2007.09593
    # Source: Materials Cloud Archive (DOI: 10.24435/materialscloud:wy-kn)
    # Contains ~100k conformations for each of 10 small organic molecules
    # Level of theory: PBE/def2-SVP with very tight SCF convergence (ORCA)
    # Coordinate units: Angstrom | Energy units: Hartree (converted from kcal/mol)
    # Force units: Hartree/Angstrom (converted from kcal/mol/Angstrom)
    # CRITICAL: DO NOT train on >1000 samples due to autocorrelation in MD time-series
    
    # Molecular identifiers (1 key)
    molecular_identifiers:
      - molecule_name   # Molecule type identifier (aspirin, benzene, etc.)
    
    # Atomic structure properties (2 keys)
    atomic_structure:
      - atoms           # Atomic numbers (uint8 array, constant per molecule)
      - coordinates     # Cartesian coordinates in Angstrom (object array, shape: n_atoms x 3)
    
    # Scalar graph-level properties (1 key)
    scalar_graph_targets:
      - energies        # PBE/def2-SVP total energy (Hartree, float64) - converted from kcal/mol
    
    # Node-level (atomic) properties (1 key)
    node_features:
      - forces          # Atomic forces (Hartree/Angstrom, object array, shape: n_atoms x 3)
    
    # Fixed-size vector graph properties
    vector_graph_properties: []  # rMD17 does not have dipole or other vector properties
    
    # Variable-length graph properties
    variable_len_graph_properties: []  # Forces are in node_features
    
    # Metadata fields (1 key)
    metadata_fields:
      - _metadata       # Preprocessing metadata as string array (object)
    
    # Optional: Original MD17 data for comparison (if include_old_data=true during preprocessing)
    # old_energies     # Original MD17 energies (kcal/mol, float64)
    # old_forces       # Original MD17 forces (kcal/mol/Angstrom, object array)
    # old_indices      # Original MD17 conformer indices (int64)
    
    # rMD17 is DFT-based - no uncertainty fields
    uncertainty_fields: []

# ────────────────────────────────────────────────────
# ANI2X Property Availability Matrix
# ──────────────────────────────────────────────────── 
  ANI2X:
    # ANI-2x Dataset Property Availability
    # Reference: Devereux et al., J. Chem. Theory Comput. 2020, 16, 4192-4202
    # DOI: 10.1021/acs.jctc.0c00121
    # Source: Zenodo (DOI: 10.5281/zenodo.10108942)
    # Contains DFT conformations for organic molecules (H, C, N, O, S, F, Cl)
    # Level of theory: ωB97X/6-31G(d)
    # Coordinate units: Angstrom | Energy units: Hartree | Force units: Hartree/Angstrom
    # CRITICAL: ANI-2x extends ANI-1x to include sulfur (S), fluorine (F), and chlorine (Cl)
    # These 7 elements make up ~90% of drug-like molecules
    
    # Molecular identifiers (1 key)
    molecular_identifiers:
      - molecule_id     # Molecule group identifier from HDF5 (object/string)
    
    # Atomic structure properties (2 keys)
    atomic_structure:
      - atoms           # Atomic numbers (uint8 array)
      - coordinates     # Cartesian coordinates in Angstrom (object array, shape: n_atoms x 3)
    
    # Scalar graph-level properties (1 key)
    scalar_graph_targets:
      - energy          # ωB97X/6-31G(d) DFT total energy (Hartree, float64)
    
    # Node-level (atomic) properties (1 key, if available)
    node_features:
      - forces          # Atomic forces (Hartree/Angstrom, object array, shape: n_atoms x 3)
    
    # Fixed-size vector graph properties
    vector_graph_properties: []  # ANI-2x does not have dipole or other vector properties
    
    # Variable-length graph properties
    variable_len_graph_properties: []  # Forces are in node_features
    
    # Metadata fields (1 key)
    metadata_fields:
      - _metadata       # Preprocessing metadata as string array (object)
    
    # ANI-2x is DFT-based - no uncertainty fields
    uncertainty_fields: []

# ────────────────────────────────────────────────────
# XXMD Property Availability Matrix
# ──────────────────────────────────────────────────── 
  XXMD:
    # xxMD (Extended Excited-state Molecular Dynamics) Dataset Property Availability
    # Reference: Pengmei, Liu, Shu. Scientific Data 11, 222 (2024)
    # DOI: 10.1038/s41597-024-03019-3
    # Source: Zenodo (DOI: 10.5281/zenodo.10393859)
    # Contains nonadiabatic dynamics trajectories for 4 photochemically active molecules
    # Molecules: azobenzene, dithiophene, malonaldehyde, stilbene
    # Level of theory (xxMD-DFT): M06 exchange-correlation functional (spin-polarized KS-DFT)
    # Coordinate units: Angstrom | Energy units: Hartree (converted from eV)
    # Force units: Hartree/Angstrom (converted from eV/Angstrom)
    # CRITICAL: xxMD samples broader configuration space including transition states
    # and conical intersections - more challenging benchmark than MD17/rMD17
    
    # Molecular identifiers (1 key)
    molecular_identifiers:
      - molecule_name   # Molecule type identifier (azobenzene, dithiophene, malonaldehyde, stilbene)
    
    # Atomic structure properties (2 keys)
    atomic_structure:
      - atoms           # Atomic numbers (uint8 array)
      - coordinates     # Cartesian coordinates in Angstrom (object array, shape: n_atoms x 3)
    
    # Scalar graph-level properties (1 key)
    scalar_graph_targets:
      - energy          # M06 DFT total energy (Hartree, converted from eV, float64)
    
    # Node-level (atomic) properties (1 key)
    node_features:
      - forces          # Atomic forces (Hartree/Angstrom, converted from eV/Angstrom, object array)
    
    # Fixed-size vector graph properties
    vector_graph_properties: []  # xxMD does not have dipole or other vector properties
    
    # Variable-length graph properties
    variable_len_graph_properties: []  # Forces are in node_features
    
    # Metadata fields (1 key)
    metadata_fields:
      - _metadata       # Preprocessing metadata as string array (object)
    
    # Optional: Split information (if include_splits=true during preprocessing)
    # split             # train/val/test split indicator (object/string)
    
    # xxMD is DFT-based - no uncertainty fields
    uncertainty_fields: []

# ────────────────────────────────────────────────────
# QDPi Property Availability Matrix
# ──────────────────────────────────────────────────── 
  QDPi:
    # QDπ (Quantum Deep Potential Interaction) Dataset Property Availability
    # Reference: Zeng et al., Scientific Data 12, 693 (2025)
    # DOI: 10.1038/s41597-025-04972-3
    # Source: Zenodo (DOI: 10.5281/zenodo.14970869)
    # Contains ~1.6 million structures for drug discovery ML potentials
    # Data sources: SPICE, ANI, GEOM, FreeSolv, RE, COMP6 (selected via active learning)
    # Level of theory: ωB97M-D3(BJ)/def2-TZVPPD (highly accurate functional)
    # Elements: H, Li, C, N, O, F, Na, P, S, Cl, K, Br, I (13 elements)
    # Coordinate units: Angstrom | Energy units: Hartree (converted from eV)
    # Force units: Hartree/Angstrom (converted from eV/Angstrom)
    # CRITICAL: Designed for drug-like molecules and biopolymer fragments
    
    # Molecular identifiers (1 key)
    molecular_identifiers:
      - formula         # Chemical formula group identifier from HDF5 (object/string)
    
    # Atomic structure properties (2 keys)
    atomic_structure:
      - atoms           # Atomic numbers (uint8 array)
      - coordinates     # Cartesian coordinates in Angstrom (object array, shape: n_atoms x 3)
    
    # Scalar graph-level properties (1 key)
    scalar_graph_targets:
      - energy          # ωB97M-D3(BJ)/def2-TZVPPD total energy (Hartree, converted from eV, float64)
    
    # Node-level (atomic) properties (1 key)
    node_features:
      - forces          # Atomic forces (Hartree/Angstrom, converted from eV/Angstrom, object array)
    
    # Fixed-size vector graph properties
    vector_graph_properties: []  # QDπ does not have dipole or other vector properties
    
    # Variable-length graph properties
    variable_len_graph_properties: []  # Forces are in node_features
    
    # Metadata fields (1 key)
    metadata_fields:
      - _metadata       # Preprocessing metadata as string array (object)
    
    # QDπ is DFT-based - no uncertainty fields
    uncertainty_fields: []

# ─────────────────────────────────────────────────────────────────────────────────
# Dataset Configuration: Defines which properties to include in the PyG Data object
# ─────────────────────────────────────────────────────────────────────────────────
data_config:
  # Property selection based on dataset type
  property_selection:
# ────────────────────────────────────────────────────
# DFT Configuration
# ──────────────────────────────────────────────────── 
    DFT:
      # Scalar graph-level targets to be included in pyg_data.y
      scalar_graph_targets_to_include:
        - Etot
        - U0
        - zpves
        - gap
        - Eee
        - Exc
        - Edisp
      # Node-level features to be added to pyg_data.x
      node_features_to_add:
        - Qmulliken     # Essential for mulliken_charge structural feature
        - Vesp
      # Fixed-size vector graph properties to be added as separate attributes
      vector_graph_properties_to_include:
        - dipole
        - quadrupole
        - octupole
        - hexadecapole
        - rots
      # Variable-length graph properties to be added as separate attributes
      variable_len_graph_properties_to_include:
        - freqs
        - vibmodes
      
      # DFT-specific settings
      # The key from which to calculate atomization energy
      calculate_atomization_energy_from: Etot
      # The name of the key for the calculated atomization energy
      atomization_energy_key_name: Etot_ATOM
      # Vibrational refinement settings
      vibration_refinement:
        comparison_tolerance: 1.0e-4 # Tolerance for numerical comparisons when refining freqs and vibmodes
# ────────────────────────────────────────────────────
# DMC Configuration
# ────────────────────────────────────────────────────     
    DMC:
      # Scalar graph-level targets to be included in pyg_data.y
      scalar_graph_targets_to_include:
        - Etot  # Only Etot is a target; std is uncertainty metadata
      # Node-level features (DMC typically doesn't have these)
      node_features_to_add: []
      # Vector properties (DMC typically doesn't have these)
      vector_graph_properties_to_include: []
      # Variable-length properties (DMC typically doesn't have these)
      variable_len_graph_properties_to_include: []
# ────────────────────────────────────────────────────
# Wavefunction Configuration
# ────────────────────────────────────────────────────     
    Wavefunction:
      # Scalar graph-level targets for wavefunction datasets
      scalar_graph_targets_to_include:
        # Primary energy targets
        # - total_energy_Hartree         # NOT AVAILABLE - causes NaN errors
        # - total_energy_eV              # NOT AVAILABLE - causes NaN errors
        - homo_energy_eV                 # HOMO orbital energy (eV)
        - lumo_energy_eV                 # LUMO orbital energy (eV)
        - homo_lumo_gap_eV               # HOMO-LUMO gap (eV)
        
        # Orbital indices
        - homo_index                     # Index of HOMO orbital
        - lumo_index                     # Index of LUMO orbital
        
        # Orbital energy statistics
        - mo_energy_mean_eV              # Mean MO energy (eV)
        - mo_energy_std_eV               # Std dev of MO energies (eV)
        - mo_energy_min_eV               # Minimum MO energy (eV)
        - mo_energy_max_eV               # Maximum MO energy (eV)
        
        # Chemical descriptors (all in eV)
        - ionization_potential_eV        # Ionization potential approx (eV)
        - electron_affinity_eV           # Electron affinity approx (eV)
        - chemical_hardness_eV           # Chemical hardness (eV)
        - chemical_potential_eV          # Chemical potential (eV)
        - electrophilicity_eV            # Electrophilicity index (eV)
        
        # Electronic structure properties
        - n_electrons                    # Total number of electrons
        - n_basis_functions              # Number of basis functions
        - n_occupied_orbitals            # Number of occupied MOs
        - n_virtual_orbitals             # Number of virtual MOs
        - n_shells                       # Number of atomic shells
        
        # Molecular properties
        - molecular_weight               # Molecular weight (amu)
      
      # Node-level features - currently none from .molden files
      node_features_to_add: []
      
      # Vector graph properties - currently none from .molden files
      vector_graph_properties_to_include: []
      
      # Variable-length properties - MO data
      variable_len_graph_properties_to_include:
        - mo_energies                    # All molecular orbital energies
        - mo_occupations                 # All molecular orbital occupations
        # Note: mo_coefficients are available but extremely large
        # Uncomment below only if needed:
        # - mo_coefficients
# ────────────────────────────────────────────────────
# QM9 Configuration
# ──────────────────────────────────────────────────── 
    QM9:
      # QM9 Dataset Property Selection
      # Reference: Ramakrishnan et al., Scientific Data 1, 140022 (2014)
      
      # Scalar graph-level targets to be included in pyg_data.y
      scalar_graph_targets_to_include:
        # Primary energy targets (Hartree)
        - U0              # Internal energy at 0K (most common target)
        - U               # Internal energy at 298.15K
        - H               # Enthalpy at 298.15K
        - G               # Free energy at 298.15K
        - zpve            # Zero point vibrational energy
        
        # Electronic properties
        - homo            # HOMO energy (Hartree)
        - lumo            # LUMO energy (Hartree)
        - gap             # HOMO-LUMO gap (Hartree)
        
        # Other properties
        - mu              # Dipole moment (Debye)
        - alpha           # Isotropic polarizability (Bohr³)
        - Cv              # Heat capacity (cal/(mol·K))
        
        # Rotational constants (GHz)
        - A
        - B
        - C
        
        # Electronic spatial extent
        - r2              # (Bohr²)
      
      # Node-level features
      node_features_to_add:
        - Qmulliken       # Mulliken partial charges
      
      # Vector graph properties
      vector_graph_properties_to_include: []
      
      # Variable-length properties
      variable_len_graph_properties_to_include:
        - freqs           # Vibrational frequencies (cm⁻¹)
      
      # QM9-specific settings
      # Calculate atomization energy from U0
      calculate_atomization_energy_from: U0
      # The name of the key for the calculated atomization energy
      atomization_energy_key_name: U0_ATOM
# ────────────────────────────────────────────────────
# ANI1X Configuration
# ──────────────────────────────────────────────────── 
    ANI1X:
      # ANI-1x Dataset Property Selection
      # Reference: Smith et al., Scientific Data 7, 134 (2020)
      # Level of theory: ωB97x/6-31G* (wb97x_dz)
      
      # Scalar graph-level targets to be included in pyg_data.y
      scalar_graph_targets_to_include:
        - energy          # ωB97x/6-31G* DFT total energy (Hartree)
      
      # Node-level features to be added to pyg_data.x
      node_features_to_add:
        - hirshfeld_charges   # Hirshfeld atomic charges (e) - recommended for charge features
        # - cm5_charges       # CM5 atomic charges (e) - alternative charge scheme
        # - forces            # Atomic forces (Hartree/Angstrom) - for force-field training
      
      # Fixed-size vector graph properties
      vector_graph_properties_to_include:
        - dipole          # Molecular dipole moment (Debye)
      
      # Variable-length graph properties
      variable_len_graph_properties_to_include: []
      
      # ANI1X-specific settings
      # Calculate atomization energy from total energy
      calculate_atomization_energy_from: energy
      # The name of the key for the calculated atomization energy
      atomization_energy_key_name: energy_ATOM
# ────────────────────────────────────────────────────
# ANI1CCX Configuration
# ──────────────────────────────────────────────────── 
    ANI1CCX:
      # ANI-1ccx Dataset Property Selection
      # Reference: Smith et al., Scientific Data 7, 134 (2020)
      # Level of theory: CCSD(T)/CBS (primary), ωB97x/6-31G* (secondary)
      # CRITICAL: ANI-1ccx is a ~500k conformer subset of ANI-1x with CC energies
      
      # Scalar graph-level targets to be included in pyg_data.y
      scalar_graph_targets_to_include:
        - ccsd_energy     # CCSD(T)/CBS coupled-cluster energy (Hartree) - PRIMARY TARGET
        # - dft_energy    # ωB97x/6-31G* DFT energy (Hartree) - uncomment for comparison
      
      # Node-level features to be added to pyg_data.x
      node_features_to_add:
        - hirshfeld_charges   # Hirshfeld atomic charges (e) - recommended for charge features
        # - cm5_charges       # CM5 atomic charges (e) - alternative charge scheme
        # - forces            # Atomic forces (Hartree/Angstrom) - for force-field training
      
      # Fixed-size vector graph properties
      vector_graph_properties_to_include:
        - dipole          # Molecular dipole moment (Debye)
      
      # Variable-length graph properties
      variable_len_graph_properties_to_include: []
      
      # ANI1CCX-specific settings
      # Calculate atomization energy from coupled-cluster energy (higher accuracy than DFT)
      calculate_atomization_energy_from: ccsd_energy
      # The name of the key for the calculated atomization energy
      atomization_energy_key_name: ccsd_energy_ATOM
# ────────────────────────────────────────────────────
# rmd17 Configuration
# ──────────────────────────────────────────────────── 
    RMD17:
      # rMD17 (Revised MD17) Dataset Property Selection
      # Reference: Christensen & von Lilienfeld, Mach. Learn.: Sci. Technol. 1, 045018 (2020)
      # Level of theory: PBE/def2-SVP with very tight SCF convergence
      # CRITICAL: DO NOT train on >1000 samples due to autocorrelation in MD time-series
      
      # Scalar graph-level targets to be included in pyg_data.y
      scalar_graph_targets_to_include:
        - energies        # PBE/def2-SVP total energy (Hartree)
      
      # Node-level features to be added to pyg_data.x
      node_features_to_add:
        - forces          # Atomic forces (Hartree/Angstrom) - key feature for force-field training
      
      # Fixed-size vector graph properties
      vector_graph_properties_to_include: []
      
      # Variable-length graph properties
      variable_len_graph_properties_to_include: []
      
      # RMD17-specific settings
      # Calculate atomization energy from total energy
      calculate_atomization_energy_from: energies
      # The name of the key for the calculated atomization energy
      atomization_energy_key_name: energies_ATOM
# ────────────────────────────────────────────────────
# ANI2X Configuration
# ──────────────────────────────────────────────────── 
    ANI2X:
      # ANI-2x Dataset Property Selection
      # Reference: Devereux et al., J. Chem. Theory Comput. 2020, 16, 4192-4202
      # Level of theory: ωB97X/6-31G(d)
      # Extends ANI-1x to H, C, N, O, S, F, Cl (7 elements, ~90% of drug-like molecules)
      
      # Scalar graph-level targets to be included in pyg_data.y
      scalar_graph_targets_to_include:
        - energy          # ωB97X/6-31G(d) DFT total energy (Hartree)
      
      # Node-level features to be added to pyg_data.x
      node_features_to_add:
        - forces          # Atomic forces (Hartree/Angstrom) - for force-field training
      
      # Fixed-size vector graph properties
      vector_graph_properties_to_include: []
      
      # Variable-length graph properties
      variable_len_graph_properties_to_include: []
      
      # ANI2X-specific settings
      # Calculate atomization energy from total energy
      calculate_atomization_energy_from: energy
      # The name of the key for the calculated atomization energy
      atomization_energy_key_name: energy_ATOM
# ────────────────────────────────────────────────────
# XXMD Configuration
# ──────────────────────────────────────────────────── 
    XXMD:
      # xxMD (Extended Excited-state Molecular Dynamics) Dataset Property Selection
      # Reference: Pengmei, Liu, Shu. Scientific Data 11, 222 (2024)
      # Level of theory: M06 (spin-polarized KS-DFT)
      # Contains nonadiabatic dynamics trajectories - samples broader configuration space
      # CRITICAL: More challenging benchmark than MD17/rMD17 due to transition states
      
      # Scalar graph-level targets to be included in pyg_data.y
      scalar_graph_targets_to_include:
        - energy          # M06 DFT total energy (Hartree, converted from eV)
      
      # Node-level features to be added to pyg_data.x
      node_features_to_add:
        - forces          # Atomic forces (Hartree/Angstrom) - for force-field training
      
      # Fixed-size vector graph properties
      vector_graph_properties_to_include: []
      
      # Variable-length graph properties
      variable_len_graph_properties_to_include: []
      
      # XXMD-specific settings
      # Calculate atomization energy from total energy
      calculate_atomization_energy_from: energy
      # The name of the key for the calculated atomization energy
      atomization_energy_key_name: energy_ATOM
# ────────────────────────────────────────────────────
# QDPi Configuration
# ──────────────────────────────────────────────────── 
    QDPi:
      # QDπ (Quantum Deep Potential Interaction) Dataset Property Selection
      # Reference: Zeng et al., Scientific Data 12, 693 (2025)
      # Level of theory: ωB97M-D3(BJ)/def2-TZVPPD (highly accurate functional)
      # Contains ~1.6 million structures for drug discovery ML potentials
      # Elements: H, Li, C, N, O, F, Na, P, S, Cl, K, Br, I (13 elements)
      # CRITICAL: Energies/forces converted from eV to Hartree during preprocessing
      
      # Scalar graph-level targets to be included in pyg_data.y
      scalar_graph_targets_to_include:
        - energy          # ωB97M-D3(BJ)/def2-TZVPPD total energy (Hartree, converted from eV)
      
      # Node-level features to be added to pyg_data.x
      node_features_to_add:
        - forces          # Atomic forces (Hartree/Angstrom) - for force-field training
      
      # Fixed-size vector graph properties
      vector_graph_properties_to_include: []
      
      # Variable-length graph properties
      variable_len_graph_properties_to_include: []
      
      # QDPi-specific settings
      # Calculate atomization energy from total energy
      calculate_atomization_energy_from: energy
      # The name of the key for the calculated atomization energy
      atomization_energy_key_name: energy_ATOM

# ──────────────────────────────────────────
# Common settings for all available datasets
# ──────────────────────────────────────────
  common_settings:
    # Test molecule limit for debugging
    test_molecule_limit: 100 # Set to a specific number for testing, or ""null"" for full dataset
    
    # Enhanced structural features integration
    structural_feature_integration:
      # Pass coordinates to structural feature extraction for 3D features
      pass_coordinates: true
      # Pass Mulliken charges for enhanced atom features (DFT only)
      pass_mulliken_charges: true
      # Enable stereochemistry assignment before structural feature extraction
      enable_stereochemistry_preprocessing: true

# ─────────────────────────────────────────────────────────────────────────
# Dataset Filtering Configuration: Defines criteria for filtering molecules
# ─────────────────────────────────────────────────────────────────────────
filter_config:
  # Common filters applied to both DFT and DMC datasets
  
  # Maximum number of atoms allowed in a molecule
  max_atoms: 50
  
  # Minimum number of atoms allowed in a molecule
  # min_atoms: 5 # Uncomment and set if needed

  # Heavy atom filter:
  # mode: 'include' - only include molecules with specified heavy atoms
  # mode: 'exclude' - exclude molecules with specified heavy atoms
  # atoms: list of atom symbols (e.g., ['C', 'N'])

  # Example 1: Exclude molecules containing Bromine or Chlorine
  # heavy_atom_filter:
  #   mode: exclude
  #   atoms:
  #     - Br
  #     - Cl

  # Example 2: Only include molecules that contain ONLY Carbon, Nitrogen, Oxygen, and Fluorine as heavy atoms
  # heavy_atom_filter:
  #   mode: include
  #   atoms:
  #     - C
  #     - N
  #     - O
  #     - F

  # Example 3: Focus on drug-like molecules (common pharmaceutical atoms)
  # heavy_atom_filter:
  #   mode: include
  #   atoms:
  #     - C
  #     - N
  #     - O
  #     - F
  #     - S
  #     - P
  #     - Cl

  # DMC-specific filtering (only applied when dataset_type = "DMC")
  # Filter based on DMC uncertainty
  # dmc_uncertainty_filter:
  #   max_uncertainty: 0.05  # Exclude molecules with std > 0.05 Hartree
  #   filter_invalid_uncertainties: true  # Remove NaN/infinite uncertainties

# ───────────────────────────
# PLUGIN SYSTEM CONFIGURATION 
# ───────────────────────────
# The plugin system allows loading custom graph transformations from external packages.
# This enables extending Milia's capabilities without modifying core code.
#
# See docs/PLUGIN_SYSTEM_GUIDE.md for detailed documentation on:
#   - Creating custom plugins
#   - Plugin validation requirements
#   - Security considerations
#   - Distribution best practices

plugins:
  # Enable or disable the entire plugin system
  # When false, all plugin-related operations are skipped
  enabled: true
  
  # List of directories to search for plugins
  # Paths can be absolute or relative to the project root
  # Each directory should contain plugin packages with plugin.yaml metadata
  plugin_paths:
    - milia_pipeline/plugins        # Local plugins directory (default)
    # - ~/.milia/plugins             # User-specific plugins
    # - /opt/milia/shared_plugins    # System-wide shared plugins
  
  # Plugin Discovery Settings
  # Automatically discover plugins in plugin_paths during startup
  auto_discover: true
  
  # Automatically validate plugins when they are discovered
  # Recommended to keep enabled for security and stability
  auto_validate: true
  
  # Plugin Validation Level
  # Controls how strictly plugins are validated
  # Options: "strict", "standard", "permissive", "disabled"
  #
  # - strict: Full validation including security scanning (production)
  # - standard: Basic validation, skip expensive checks (recommended)
  # - permissive: Minimal validation, trust plugins (development only)
  # - disabled: No validation (not recommended)
  validation_level: "standard"
  
  # Plugin Whitelisting and Blacklisting
  
  # Trusted plugins: Pre-approved plugins that skip some validation steps
  # Use this to speed up loading of known-good plugins
  trusted_plugins: []
    # - official_molecular_transforms
    # - quantum_chemistry_extensions
  
  # Disabled plugins: Plugins that should never be loaded
  # Use this to prevent loading of problematic or deprecated plugins
  disabled_plugins: []
    # - deprecated_transform_v1
    # - experimental_buggy_plugin
  
  # Security Settings
  
  # Allow experimental plugins (not fully validated/tested)
  allow_experimental: true
  
  # Allow plugins to override built-in transforms
  # Set to false in production for security
  allow_override_builtin: false
  
  # Enforce plugin checksums for integrity verification
  enforce_checksums: false
  
  # Enable security scanning of plugin code
  security_scanning: false
  
  # Error Handling
  
  # Fail immediately if plugin loading/validation fails
  # If false, log warning and continue without the plugin
  fail_on_plugin_error: false
  
  # Maximum time (seconds) for plugin initialization
  # Prevents hanging on slow/buggy plugins
  initialization_timeout: 30
  
  # Logging
  
  # Log level for plugin operations
  # Options: "DEBUG", "INFO", "WARNING", "ERROR"
  log_level: "INFO"
  
  # Log plugin discovery details
  log_discovery: true
  
  # Log plugin validation details
  log_validation: true

# ───────────────────────────────────
# MOLECULAR DESCRIPTORS CONFIGURATION
# ───────────────────────────────────

molecular_descriptors:
  # Enable molecular descriptor calculation
  enabled: true
  
  # Descriptor categories to compute
  # Each category can be individually enabled/disabled
  # NOTE: Category names must match DescriptorCategory enum values:
  #   constitutional, topological, electronic, geometric, drug_likeness, fragments
  # NOTE: Descriptor names must match RDKit function names (case-sensitive)
  categories:
    constitutional:
      enabled: true
      descriptors:
        # Basic molecular properties (RDKit names)
        - MolWt
        - NumHeavyAtoms
        - NumHeteroatoms
        - NumRotatableBonds
        - NumHDonors
        - NumHAcceptors
        - NumAromaticRings
        - NumAliphaticRings
        
        # Lipophilicity and polarity
        - MolLogP
        - TPSA
        - MolMR
    
    topological:
      enabled: true
      descriptors:
        # Graph-based descriptors (RDKit names)
        - BalabanJ
        - BertzCT
        
        # Kappa shape indices
        - Kappa1
        - Kappa2
        - Kappa3
        
        # Connectivity indices
        - Chi0v
        - Chi1v
        - Chi2v
        - HallKierAlpha
    
    electronic:
      enabled: false  # Requires quantum chemistry calculations
      descriptors:
        - MaxPartialCharge
        - MinPartialCharge
        - MaxAbsPartialCharge
        - MinAbsPartialCharge
    
    # NOTE: 'fingerprints' is NOT a valid DescriptorCategory enum value.
    # Fingerprints are handled separately by the fingerprint module.
    # Comment out to avoid "Unknown descriptor category: fingerprints" error.
    # fingerprints:
    #   enabled: true
    #   types:
    #     # Morgan/ECFP fingerprints
    #     - morgan:
    #         radius: 2
    #         n_bits: 2048
    #     
    #     # MACCS keys
    #     - maccs: {}
    #     
    #     # RDKit fingerprints
    #     - rdkit:
    #         min_path: 1
    #         max_path: 7
    #         n_bits: 2048
    #     
    #     # Atom pair fingerprints
    #     - atom_pair:
    #         n_bits: 2048
    #     
    #     # Topological torsion fingerprints
    #     - topological_torsion:
    #         n_bits: 2048
  
  # Descriptor normalization
  normalization:
    enabled: true
    method: "standardize"  # Options: "standardize", "minmax", "robust", "none"
    per_descriptor: true
  
  # Feature selection
  feature_selection:
    enabled: false
    method: "variance_threshold"  # Options: "variance_threshold", "correlation", "mutual_info"
    threshold: 0.01
  
  # Advanced fingerprint settings
  fingerprint_settings:
    # Use chirality information
    use_chirality: true
    
    # Use bond types
    use_bond_types: true
    
    # Count-based vs binary fingerprints
    count_based: false
    
    # For Morgan fingerprints
    morgan:
      use_features: false
      radius: 2
      n_bits: 2048
  
  # Caching settings
  cache_descriptors: true
  # Cache path (null = auto-generate in dataset directory)
  cache_path: null
  
  # Parallel computation settings
  parallel_computation: false
  num_workers: 1
  
  # Error handling mode
  # Options: "strict" (raise on error), "warn" (log warning), "skip" (silent skip)
  error_handling: warn
  
  # Validation mode
  # Options: "strict" (full validation), "standard" (basic validation), "permissive" (minimal validation)
  validation_mode: standard
  
  # Descriptor calculation logging
  # Options: "minimal" (only initialization), "standard" (+ per-molecule summary), "detailed" (+ failed descriptors per molecule)
  logging_level: standard


# ───────────────────────────────────────────────
# PYTORCH GEOMETRIC TRANSFORMATIONS CONFIGURATION
# ───────────────────────────────────────────────
transformations:
  # ──────────────────────────────────────────────────────────────────
  # STANDARD TRANSFORMS - Always applied before any experimental setup
  # ──────────────────────────────────────────────────────────────────
  # Production-ready PyG transforms applied during dataset loading.
  # These run BEFORE any experimental setup transforms.
  standard_transforms:
    - name: "AddSelfLoops"
      enabled: false
      params:
        # CRITICAL: attr='edge_attr' tells AddSelfLoops to handle edge_attr tensor
        # Without this, AddSelfLoops only handles edge_weight, causing shape mismatch:
        #   edge_index.size(1) != edge_attr.size(0)
        # See: https://pytorch-geometric.readthedocs.io/en/latest/generated/torch_geometric.transforms.AddSelfLoops.html
        attr: "edge_attr"
        fill_value: 0.0  # Fill self-loop edge features with zeros
    
    # Normalize node features (X)
    - name: "NormalizeFeatures"
      enabled: true
      params:
        attrs: ["x"]
    
    # Standardize target labels (Y) - CRITICAL for large energy values
    # Z-score normalization: mean=0, std=1
    - name: "StandardizeTargets"
      enabled: true
      params:
        attrs: ["y"]
        eps: 1.0e-8

  # ───────────────────────────────────────────────────────
  # EXPERIMENTAL SETUPS - For research and ablation studies
  # ───────────────────────────────────────────────────────
  # Named configurations for systematic experiments.
  # These run AFTER standard transforms.
  experimental_setups:
    # Baseline: empty transforms list - uses only standard_transforms (not experimental)
    baseline:
      name: "baseline"
      description: "Baseline configuration - uses only standard transforms"
      enabled: true
      transforms: []
    
    # Custom Milia-specific transforms 
    milia_quantum_enhanced:
      name: "milia_quantum_enhanced"
      description: "Milia quantum-enhanced setup with vibrational mode normalization and charge scaling"
      enabled: false
      transforms:
        - name: "NormalizeVibrationalModes"
          enabled: true
          params:
            normalize_per_mode: true
            epsilon: 1.0e-8
        - name: "ScaleMullikenCharges"
          enabled: true
          params:
            scale_factor: 1.0
            center: false
        - name: "GCNNorm"
          enabled: true
          params:
            add_self_loops: false
    
    milia_filtered:
      name: "milia_filtered"
      description: "Milia setup with DMC uncertainty filtering for high-quality training data"
      enabled: false
      transforms:
        - name: "FilterByDMCUncertainty"
          enabled: true
          params:
            max_uncertainty: 0.05
            remove: false
        - name: "NormalizeVibrationalModes"
          enabled: true
          params:
            normalize_per_mode: true
        - name: "GCNNorm"
          enabled: true
    
    milia_ablation_no_vibmodes:
      name: "milia_ablation_no_vibmodes"
      description: "Milia ablation study setup - no vibrational mode normalization"
      enabled: false
      transforms:
        - name: "ScaleMullikenCharges"
          enabled: true
          params:
            scale_factor: 1.0
            center: false
        - name: "GCNNorm"
          enabled: true
    
    # Example: Using plugin transforms in experimental setup
    # Uncomment and modify when you have plugins enabled
    # plugin_example_setup:
    #   name: "plugin_example_setup"
    #   description: "Example setup using custom plugin transforms"
    #   enabled: false
    #   transforms:
    #     # Plugin transforms are referenced by name just like built-in transforms
    #     - name: "EnergyScaleAugmentation"  # From quantum_transforms_extended plugin
    #       enabled: true
    #       params:
    #         scale_range: [0.95, 1.05]
    #     - name: "ComplexityFilter"  # From molecular_filters_advanced plugin
    #       enabled: true
    #       params:
    #         max_complexity: 0.8
  
  # Default setup to use
  default_setup: "baseline"
 
  # Validation settings
  validation:
    enabled: true
    strict_mode: false
    warn_on_unavailable: true
  # - name: Distance
  #  kwargs:
  #    norm: False
  #    max_value: 10.0  # Works well with bond_length features
  # - name: OneHotDegree
  #  kwargs:
  #      max_degree: 5  
  # Additional transforms that work well with enhanced structural features


# ────────────────────────────────────────
# CONFIGURATION EXAMPLES AND DOCUMENTATION
# ────────────────────────────────────────

# Example configurations for different use cases:

# Configuration 1: Basic structural features (backward compatible)
# structural_features:
#   atom: [degree, hybridization, is_aromatic]
#   bond: [bond_type, is_conjugated]

# Configuration 2: Enhanced 2D features (no 3D geometry required)  
# structural_features:
#   atom: [degree, hybridization, is_aromatic, mulliken_charge, chirality]
#   bond: [bond_type, is_conjugated, stereo]

# Configuration 3: Full 3D-enhanced features (current default)
# structural_features:
#   atom: [degree, hybridization, is_aromatic, mulliken_charge, num_aromatic_bonds, chirality]
#   bond: [bond_type, is_conjugated, stereo, bond_length]

# Configuration 4: Minimal high-performance features for large-scale training
# structural_features:
#   atom: [degree, is_aromatic, mulliken_charge]
#   bond: [bond_type, bond_length_binned]

# ────────────────────────────
# PLUGIN SYSTEM USAGE EXAMPLES
# ────────────────────────────

# Example 1: Enable plugins with default settings
# plugins:
#   enabled: true
#   plugin_paths:
#     - ./plugins
#   auto_discover: true
#   auto_validate: true
#   validation_level: "standard"

# Example 2: Production configuration with strict validation
# plugins:
#   enabled: true
#   plugin_paths:
#     - /opt/milia/plugins
#   auto_discover: true
#   auto_validate: true
#   validation_level: "strict"
#   trusted_plugins:
#     - official_molecular_transforms
#   allow_experimental: false
#   enforce_checksums: true
#   security_scanning: true
#   fail_on_plugin_error: true

# Example 3: Development configuration with permissive validation
# plugins:
#   enabled: true
#   plugin_paths:
#     - ./plugins
#     - ./dev_plugins
#   auto_discover: true
#   auto_validate: true
#   validation_level: "permissive"
#   allow_experimental: true
#   allow_override_builtin: true
#   fail_on_plugin_error: false

# Example 4: Disable specific problematic plugins
# plugins:
#   enabled: true
#   plugin_paths:
#     - ./plugins
#   disabled_plugins:
#     - deprecated_transform_v1
#     - buggy_experimental_transform
#   validation_level: "standard"

# ───────────────────────────
# MODELS MODULE CONFIGURATION
# ───────────────────────────

models:
  enabled: false                         # MASTER SWITCH (true OR false) that controls whether the entire models module is active in the Milia pipeline.
  
  # ───────────────────────────────────────────────────────────
  # MODEL SELECTION (ENHANCED)
  # ───────────────────────────────────────────────────────────
  
  selection:
    # Mode determines how model is created
    
    mode: "ensemble"                         # "single", "custom", "ensemble"
    
    task_type: "graph_regression"         # node_regression, node_classification,
                                          # graph_regression, graph_classification,
                                          # link_prediction, edge_regression, edge_classification
    

    model_name: "ensemble"                   # ARGA + ARGVA ensemble - Adversarial autoencoder ensemble
                                             # Use "custom" when mode="custom"
                                             # Use "ensemble" when mode="ensemble"
    
    # ─────────────────────────────────────────────────────────
    # GLOBAL POOLING METHOD (For graph-level tasks)
    # ─────────────────────────────────────────────────────────
    # Single Model with Different Pooling Methods
    # Configures the global pooling strategy used to aggregate
    # node embeddings into graph-level representations.
    #
    # Available options:
    #   - "mean": Average pooling (default) - stable gradients, balanced
    #   - "max":  Max pooling - captures dominant features
    #   - "add":  Sum pooling - preserves graph size information
    #
    # PyG Reference: torch_geometric.nn.global_mean_pool, 
    #                global_max_pool, global_add_pool
    # ─────────────────────────────────────────────────────────
    pooling_method: "mean"               # Options: "mean", "max", "add"
    
    # Optional baseline for comparison
    baseline_model: null
    
    # ─────────────────────────────────────────────────────────
    # TARGET SELECTION
    # ─────────────────────────────────────────────────────────
    # Configure target level, source attribute, and column selection
    # for training on graph-level, node-level, or edge-level tasks.
    #
    # DYNAMIC: Works with any dataset, any task type, any source attribute
    # PRODUCTION-READY: Smart auto-detection with explicit override options
    # FUTURE-PROOF: Extensible for custom attributes and new task types
    # ─────────────────────────────────────────────────────────
    target_selection:
      # ─────────────────────────────────────────────────────────
      # LEVEL AND SOURCE CONFIGURATION
      # ─────────────────────────────────────────────────────────
      # Target level: Determines what entity the targets describe
      # - "auto": Infer from task_type (RECOMMENDED)
      #           node_* → node, graph_* → graph, edge_*/link_* → edge
      # - "graph": Graph-level targets (one target per graph)
      # - "node": Node-level targets (one target per node)
      # - "edge": Edge-level targets (one target per edge)
      #
      # Examples:
      #   target_level: "auto"           # Let system infer from task_type
      #   target_level: "node"           # Force node-level (e.g., node property prediction)
      #   target_level: "edge"           # Force edge-level (e.g., bond property prediction)
      target_level: "auto"
      
      # Target source: Which data attribute contains the targets
      # - "auto": Try y first (PyG convention), fallback to x/edge_attr if shape mismatch
      # - "y": Standard target attribute
      # - "x": Node features (when node targets are stored in features)
      # - "edge_attr": Edge features (when edge targets are stored in features)
      # - "edge_label": Edge labels (for link prediction)
      # - "edge_y": Edge targets (for edge regression)
      # - "<custom>": Any custom attribute name (e.g., "node_labels", "bond_types")
      #
      # Examples:
      #   target_source: "auto"          # Smart detection (RECOMMENDED)
      #   target_source: "y"             # Use y directly (standard PyG datasets)
      #   target_source: "x"             # Extract targets from node features
      #   target_source: "edge_attr"     # Extract targets from edge features
      #   target_source: "atomic_charges"  # Custom attribute name
      # NOTE: For "edge_classification" can set to "edge_attr" to extract
      #       bond features as targets. Use indices to select specific column.
      target_source: "auto"
      
      # ─────────────────────────────────────────────────────────
      # COLUMN/PROPERTY SELECTION
      # ─────────────────────────────────────────────────────────
      # Select which column(s) from the source to use as targets
      #
      # MODE 1: By property name(s) - RECOMMENDED when names available
      # properties: ["gap"]              # Single property
      # properties: ["Etot", "gap"]      # Multiple properties
      properties: null                   # null = all properties (default)
      
      # MODE 2: By index/indices - Use when property names unavailable
      # indices: 3                       # Single index (4th column)
      # indices: [0, 3, 5]               # Multiple indices
      # indices: "0:3"                   # Range: columns 0, 1, 2
      # indices: null                    # null = all columns (default)
      # NOTE: For Test 21b (edge_classification), index 5 = is_aromatic (boolean)
      #       Bond feature order: bond_type(0-3), is_conjugated(4), is_aromatic(5),
      #       is_in_any_ring(6), stereo(7+), bond_length, bond_length_binned
      indices: null                       # is_aromatic: binary classification (aromatic vs non-aromatic bonds)
      
      # Validation mode
      strict: true                       # true = fail on invalid, false = warn and skip
      
      # ─────────────────────────────────────────────────────────
      # COMMON USE CASE EXAMPLES
      # ─────────────────────────────────────────────────────────
      #
      # EXAMPLE 1: Standard graph regression (QM9-style)
      #   task_type: "graph_regression"
      #   target_selection:
      #     target_level: "auto"         # → inferred as "graph"
      #     target_source: "auto"        # → uses y (graph-level targets)
      #     indices: [0, 1, 2]           # → predict first 3 properties
      #
      # EXAMPLE 2: Node classification with targets in y (Cora-style)
      #   task_type: "node_classification"
      #   target_selection:
      #     target_level: "auto"         # → inferred as "node"
      #     target_source: "auto"        # → uses y (already node-level shape)
      #
      # EXAMPLE 3: Node regression with targets in x (extract from features)
      #   task_type: "node_regression"
      #   target_selection:
      #     target_level: "auto"         # → inferred as "node"
      #     target_source: "x"           # → extract from node features
      #     indices: [5, 6]              # → columns 5,6 of x become targets
      #
      # EXAMPLE 4: Edge/bond property prediction
      #   task_type: "edge_regression"
      #   target_selection:
      #     target_level: "auto"         # → inferred as "edge"
      #     target_source: "edge_attr"   # → extract from edge features
      #     indices: [0]                 # → first column of edge_attr
      #
      # EXAMPLE 5: Link prediction (standard)
      #   task_type: "link_prediction"
      #   target_selection:
      #     target_level: "auto"         # → inferred as "edge"
      #     target_source: "auto"        # → uses edge_label automatically
      #
      # EXAMPLE 6: Custom attribute as target
      #   task_type: "node_regression"
      #   target_selection:
      #     target_level: "node"
      #     target_source: "atomic_charges"  # Custom attr in your data
      #     indices: null                    # Use all columns
  
  # ───────────────────────────────────────────────────────────
  # CUSTOM ARCHITECTURE (NEW - For mode="custom")
  # Define your own architecture with ANY NUMBER of layers in ANY ORDER
  # Choose from 120+ registered layer types (GCN, GAT, SAGE, etc.)
  # ───────────────────────────────────────────────────────────
  
  custom_architecture:                  # Build custom architectures layer-by-layer
    enabled: true                       # Set to true when mode="custom"
    name: "MyCustomArchitecture"         # Optional name for the architecture
    
    # Builder configuration
    builder_type: "sequential"           # "sequential", "parallel", "hierarchical"
    in_channels: null                    # null = auto-detect from data
    out_channels: null                   # null = infer from task_type
    
    # Layer sequence
    # NOTE: You can specify ANY NUMBER of layers in ANY ORDER
    # Available layer types: 120+ registered layers including:
    #   - Convolutional: GCNConv, GATConv, SAGEConv, GINConv, TransformerConv, etc.
    #   - Pooling: global_mean_pool, global_max_pool, global_add_pool, SAGPooling, etc.
    #   - Normalization: BatchNorm, LayerNorm, GraphNorm, InstanceNorm, etc.
    #   - Activation: ReLU, ELU, LeakyReLU, GELU, Tanh, Sigmoid, etc.
    #   - Regularization: Dropout, Dropout2d, AlphaDropout, etc.
    #   - Linear: Linear, Bilinear, LazyLinear, etc.
    # See LayerRegistry for complete list of available layers
    layers:
      - type: "GCNConv"
        params:
          out_channels: 64
      - type: "ReLU"
        params: {}
      - type: "GCNConv"
        params:
          out_channels: 32
      - type: "ReLU"
        params: {}
      - type: "global_mean_pool"
        params: {}
      - type: "Linear"
        params:
          out_features: 1
    
    # Advanced features (optional)
    residual_connections:               # Skip connections
      - start: 0                        # Start layer index
        end: 3                          # End layer index
        type: "add"                     # "add" or "concat"
    
    branches:                           # Parallel branches (optional)
      - branch_point: 1                 # Where to branch
        branch_name: "attention_path"   # Optional name
        layers:
          - type: "GATConv"
            params:
              out_channels: 64
              heads: 4
          - type: "ReLU"
            params: {}
        merge_point: 3                  # Where to merge back
        merge_strategy: "concat"        # "concat", "add", "mean", "max"
    
    # Validation settings
    validation:
      strict: true                      # Fail on validation errors
      auto_fix_channels: true           # Automatically adjust channel dims
      check_cycles: true                # Detect cycles in architecture graph
    
    # Channel optimization (optional)
    optimize_channels:
      enabled: false                    # Auto-optimize hidden dimensions
      strategy: "gradual_reduction"     # "gradual_reduction", "bottleneck", 
                                        # "expansion", "uniform"
  
  # ───────────────────────────────────────────────────────────
  # MODEL ENSEMBLE (For mode="ensemble")
  # ───────────────────────────────────────────────────────────
  
  ensemble:
    enabled: true                        # Enabled for ARGA + ARGVA ensemble
    name: "MyEnsemble"                  # Optional name for the ensemble
    
    strategy: "parallel"                # "parallel", "sequential", "hierarchical"
    
    # Models in ensemble
    models:

      # ─────────────────────────────────────────────────────────
      # Previous 2D Model Ensemble (GCN + GAT + GraphSAGE)
      # uncomment to restore
      # ─────────────────────────────────────────────────────────
      
      - name: "GCN"
        hyperparameters:
          # GCN: Graph Convolutional Network (ICLR 2017)
          # Uses x, edge_index signature (2D graph structure)
          {}                               # Empty - use registry defaults
        weight: 0.4                        # Test 15: Ensemble weighted fusion
        level: 0                           # Level 0 - parallel tier
          
      - name: "GAT"
        hyperparameters:
          # GAT: Graph Attention Network (ICLR 2018)
          # Uses x, edge_index signature (2D graph structure)
          # *** MINIMAL CONFIG for Test ***
          {}                               # Empty - use registry defaults
        weight: 0.3                        # Test 15: Ensemble weighted fusion
        level: 0                           # Level 0 - parallel tier
     
      - name: "GraphSAGE"
        hyperparameters:
          {}                               # Empty - use registry defaults
        weight: 0.3                        # Test 15: Ensemble weighted fusion
        level: 0                           # Level 0 - parallel tier


      # ─────────────────────────────────────────────────────────
      # ARGA + ARGVA Adversarial Autoencoder Ensemble
      # Both models require dynamic encoder + discriminator creation
      # Validates Fix 31 works in ensemble context
      # *** LIGHTWEIGHT CONFIG for limited resources ***
      # ─────────────────────────────────────────────────────────
      
      #  - name: "ARGA"
      #    hyperparameters:
      #      # ARGA: Adversarially Regularized Graph Auto-Encoder (IJCAI 2018)
      #      # Uses standard encoder + discriminator for adversarial training
      #      # Encoder + discriminator created dynamically via Fix 31
      #      encoder_type: "GCN"              # "GCN", "GAT", "GraphSAGE", "GIN", "PNA", "EdgeCNN"
      #      hidden_channels: 64              # Encoder hidden dimension
      #      num_layers: 2                    # Encoder depth
      #      out_channels: 32                 # Latent embedding dimension
      #      dropout: 0.0
      #    weight: 0.5                        # Equal weight in mean fusion
      #    level: 0                           # Level 0 - parallel tier
        
      #  - name: "ARGVA"
      #    hyperparameters:
      #      # ARGVA: Adversarially Regularized Variational Graph Auto-Encoder (IJCAI 2018)
      #      # Uses variational encoder (outputs mu, logstd) + discriminator
      #      # Variational encoder + discriminator created dynamically via Fix 31
      #      encoder_type: "GCN"              # GCN encoder backbone
      #      hidden_channels: 64              # Encoder hidden dimension
      #      num_layers: 2                    # Encoder depth
      #      out_channels: 32                 # Latent embedding dimension
      #      dropout: 0.0
      #    weight: 0.5                        # Equal weight in mean fusion
      #  s  level: 0                           # Level 0 - parallel tier
      
      # ─────────────────────────────────────────────────────────
      # Previous: GAE + VGAE Autoencoder Ensemble
      # Uncomment to restore
      # ─────────────────────────────────────────────────────────
      
      # - name: "GAE"
      #   hyperparameters:
      #     encoder_type: "GCN"
      #     hidden_channels: 64
      #     num_layers: 2
      #     out_channels: 16
      #     dropout: 0.0
      #   weight: 0.5
      #   level: 0
      #     
      # - name: "VGAE"
      #   hyperparameters:
      #     encoder_type: "GCN"
      #     hidden_channels: 64
      #     num_layers: 2
      #     out_channels: 16
      #     dropout: 0.0
      #   weight: 0.5
      #   level: 0
      
      # ─────────────────────────────────────────────────────────
      # Previous: Mixed Ensemble (GCN + SchNet)
      # Uncomment to restore
      # ─────────────────────────────────────────────────────────
      
      # - name: "GCN"
      #   hyperparameters:
      #     # GCN: Graph Convolutional Network (ICLR 2017)
      #     # Uses x, edge_index, batch signature (2D graph structure)
      #     # Should NOT trigger 3D validation
      #     hidden_channels: 32            # Reduced for limited resources
      #     num_layers: 2                  # Minimal layers
      #   weight: 0.5                      # Equal weight in mean fusion
      #   level: 0                         # Level 0 - parallel tier
      #     
      # - name: "SchNet"
      #   hyperparameters:
      #     # SchNet: Continuous-filter CNN for quantum interactions (NIPS 2017)
      #     # Uses z, pos, batch signature (3D molecular graphs)
      #     # SHOULD trigger 3D validation from Fix 25
      #     hidden_channels: 32            # Reduced for limited resources
      #     num_filters: 32                # Reduced from 128
      #     num_interactions: 2            # Reduced from 6
      #     cutoff: 5.0                    # MILIA default
      #   weight: 0.5                      # Equal weight in mean fusion
      #   level: 0                         # Level 0 - parallel tier
      
      # ─────────────────────────────────────────────────────────
      # Previous configs
      # uncomment to restore
      # ─────────────────────────────────────────────────────────
      
      # - name: "SchNet"
      #   hyperparameters:
      #     hidden_channels: 32
      #     num_filters: 32
      #     num_interactions: 2
      #     num_gaussians: 25
      #     cutoff: 5.0
      #     max_num_neighbors: 16
      #   weight: 0.5
      #   level: 0
      #     
      # - name: "DimeNetPlusPlus"
      #   hyperparameters:
      #     hidden_channels: 32
      #     out_channels: 1
      #     num_blocks: 2
      #     int_emb_size: 32
      #     basis_emb_size: 4
      #     out_emb_channels: 64
      #     num_spherical: 3
      #     num_radial: 3
      #     cutoff: 5.0
      #     max_num_neighbors: 16
      #   weight: 0.5
      #   level: 0
      

      
      
      # ─────────────────────────────────────────────────────────
      # Previous 2D GNN Models
      # Uncomment to restore default ensemble configuration
      # ─────────────────────────────────────────────────────────
      
      # - name: "GCN"
      #   hyperparameters:
      #     hidden_channels: 64
      #     num_layers: 3
      #     dropout: 0.5
      #     add_self_loops: true
      #   weight: 0.25                    # Weight in ensemble (for weighted fusion)
      #   level: 0                        # Level 0 - first tier
        
      # - name: "GAT"
      #   hyperparameters:
      #     hidden_channels: 64
      #     num_layers: 3
      #     heads: 4
      #     dropout: 0.5
      #     add_self_loops: true
      #   weight: 0.25
      #   level: 0                        # Level 0 - first tier

      # - name: "GIN"
      #   hyperparameters:
      #     hidden_channels: 64
      #     num_layers: 3
      #     dropout: 0.5
      #     eps: 0.0           # Optional: Initial epsilon value (default: 0.0)
      #     train_eps: false   # Optional: Make epsilon trainable (default: false)
      #   weight: 0.25
      #   level: 0
    
    # Fusion configuration
    fusion:

      method: "weighted"                     # Test 15: "weighted" fusion for parallel ensemble
      
      # Optional fusion layer (for attention/learnable fusion)
      fusion_layer:
        enabled: false                  # Disabled for mean fusion
        type: "Linear"                  # Layer type
        params:
          hidden_dim: 32
    
    # Validation settings
    validation:
      check_compatibility: true         # Ensure all models compatible
      check_output_dims: true           # Verify output dimensions match
  
  # ───────────────────────────────────────────────────────────
  # CORE CONFIGURATION (Always Active - UNCHANGED)
  # ───────────────────────────────────────────────────────────
  
  # Model Hyperparameters
  hyperparameters:
    # ─────────────────────────────────────────────────────────
    # ARGA + ARGVA Ensemble parameters (Test 57 - Fix 31)
    # ─────────────────────────────────────────────────────────
    # Test 57: ARGA + ARGVA ensemble with mean fusion
    # Individual model hyperparameters defined in ensemble.models section
    # This section provides fallback defaults
    # *** LIGHTWEIGHT CONFIG for limited resources ***
    # ─────────────────────────────────────────────────────────
    
    # Encoder configuration (fallback defaults)
    encoder_type: "GCN"                   # "GCN", "GAT", "GraphSAGE", "GIN", "PNA", "EdgeCNN"
    hidden_channels: 64                   # Encoder hidden dimension
    num_layers: 2                         # Number of GNN layers in encoder
    out_channels: 32                      # Latent embedding dimension
    dropout: 0.0                          # Dropout rate
    
    # Discriminator configuration (optional - defaults computed from out_channels)
    # discriminator_hidden_channels: 64   # Default: 2 * out_channels
    # discriminator_out_channels: 32      # Default: same as out_channels
    
    # Training
    learning_rate: 0.001
    weight_decay: 0.0001
    batch_size: 8                         # LOW RESOURCE
    epochs: 3                             # LOW RESOURCE
    
    # GCN-specific (for encoder)
    add_self_loops: true
    normalize: true
    
    # ─────────────────────────────────────────────────────────
    # SchNet-specific parameters (kept for reference)
    # ─────────────────────────────────────────────────────────
    # SchNet: Continuous-filter CNN for quantum interactions (NIPS 2017)
    # Uses z, pos, batch signature (3D molecular graphs)
    # *** LIGHTWEIGHT CONFIG for limited resources ***
    # ─────────────────────────────────────────────────────────
    num_filters: 32                      # Reduced from 128 (4x smaller)
    num_interactions: 2                  # Reduced from 6 (3x fewer layers)
    num_gaussians: 25                    # Reduced from 50 (2x fewer)
    cutoff: 5.0                          # MILIA default (PyG default is 10.0)
    max_num_neighbors: 16                # Reduced from 32 (2x fewer)
    readout: "add"                       # "add", "mean", "max"
    
    # ─────────────────────────────────────────────────────────
    # DimeNet-specific parameters (kept for reference)
    # ─────────────────────────────────────────────────────────
    # DimeNet: Directional Message Passing for Molecular Graphs (ICLR 2020)
    # Uses z, pos, batch signature (3D molecular graphs)
    # CONSTRAINT: num_spherical >= 2 (PyG hard constraint)
    # ─────────────────────────────────────────────────────────
    num_bilinear: 8                       # DimeNet-specific: bilinear layer size
    
    # ─────────────────────────────────────────────────────────
    # DimeNetPlusPlus-specific parameters (kept for reference)
    # ─────────────────────────────────────────────────────────
    # DimeNetPlusPlus: Fast and Uncertainty-Aware Directional Message Passing
    # (NeurIPS-W 2020) - 8x faster and 10% more accurate than DimeNet
    # Uses z, pos, batch signature (3D molecular graphs)
    # *** MINIMAL/LIGHTWEIGHT CONFIG for limited resources ***
    # ─────────────────────────────────────────────────────────
    # out_channels: 1                       # Output dimension (commented - using 32 for ARGA)
    num_blocks: 2                         # Reduced from 4 (2x fewer building blocks)
    int_emb_size: 32                      # DimeNetPlusPlus-specific: interaction embedding size (minimal)
    basis_emb_size: 4                     # DimeNetPlusPlus-specific: basis embedding size (minimal)
    out_emb_channels: 64                  # DimeNetPlusPlus-specific: output embedding channels (minimal)
    num_spherical: 2                      # MINIMUM valid value (PyG constraint: >= 2)
    num_radial: 4                         # Reduced from 6 (even more minimal)
    envelope_exponent: 5                  # Shape of smooth cutoff (default)
    num_before_skip: 1                    # Residual layers before skip (default)
    num_after_skip: 1                     # Reduced from 2 (minimal)
    num_output_layers: 2                  # Reduced from 3 (minimal)
  
  # Training Configuration
  training:
    # Data Splitting
    data_split:
      method: "random"                   # random, stratified, temporal, scaffold
      train_ratio: 0.8
      val_ratio: 0.1
      test_ratio: 0.1
      random_seed: 42
      shuffle: true
    
    # Loss Function
    loss:
      name: "mse"                        # Regression: mse, mae, huber, smooth_l1
                                         # Classification: cross_entropy, bce, focal
      params: {}                         # Loss-specific parameters
    
    # Optimizer
    optimizer:
      name: "adam"                       # adam, adamw, sgd, rmsprop, adagrad
      params:
        lr: 0.001
        weight_decay: 0.0001
    
    # Learning Rate Scheduler
    scheduler:
      enabled: true
      name: "reduce_on_plateau"          # reduce_on_plateau, cosine_annealing,
                                         # step_lr, exponential_lr, cyclic_lr
      params:
        mode: "min"                      # "min", "max"
        factor: 0.5
        patience: 10
        min_lr: 0.00001
    
    # Callbacks
    callbacks:
      early_stopping:
        enabled: true
        params:
          monitor: "val_loss"            # Metric to monitor
          patience: 20
          mode: "min"                    # "min", "max"
          min_delta: 0.0001
      
      model_checkpoint:
        enabled: true
        params:
          monitor: "val_loss"
          save_top_k: 3                  # Save best 3 checkpoints
          mode: "min"                    # "min", "max"
          save_last: true
          save_best: true                # Save dedicated best.pt file (default: true)
          dirpath: null                  # null = auto-generate in working_root_dir
      
      tensorboard:
        enabled: true
        params:
          log_dir: null                  # null = auto-generate
      
      lr_monitor:
        enabled: true
        params:
          logging_interval: "epoch"      # "epoch", "step"
      
      progress_bar:
        enabled: true
        params:
          refresh_rate: 1
    
    # Validation
    validation:
      check_val_every_n_epoch: 1
      val_check_interval: null           # null = once per epoch, or number of batches
    
    # Logging
    logging:
      log_every_n_steps: 50
      log_metrics: true
      log_gradients: false
      log_weights: false
  
  # Evaluation
  evaluation:
    metrics:
      # Regression metrics
      - "mse"
      - "mae"
      - "r2"
      # Classification metrics (if applicable)
      # - "accuracy"
      # - "precision"
      # - "recall"
      # - "f1"
      # - "auroc"
    
    # Test set evaluation
    test_after_training: true
    save_predictions: true
    predictions_dir: null                # null = auto-generate
    
    # ─────────────────────────────────────────────────────────────
    # VISUALIZATION CONFIGURATION
    # ─────────────────────────────────────────────────────────────
    # Controls what plots are generated after training.
    # All plots are saved to {working_root_dir}/training_plots/
    #
    # DYNAMIC: Enable/disable individual plot types
    # PRODUCTION-READY: Multiple output formats supported
    # FUTURE-PROOF: Extensible style configuration
    # ─────────────────────────────────────────────────────────────
    visualization:
      enabled: true                       # Master switch for visualization
      
      # Output formats (generated in parallel)
      formats:
        - "png"                           # Static matplotlib plots
        - "html"                          # Interactive plotly plots
        # - "pdf"                         # PDF export (requires kaleido)
      
      # Individual plot types (all enabled by default)
      plots:
        loss_curves: true                 # Train/Val loss over epochs
        metrics: true                     # All metrics in subplots (MAE, MSE, R2, AUROC, etc.)
        learning_rate: true               # Learning rate schedule
        interactive: true                 # Combined interactive dashboard (plotly)
      
      # Style configuration
      style:
        figure_size: [12, 6]              # Width, height in inches
        dpi: 150                          # Resolution for PNG output
        line_width: 2                     # Line thickness
        marker_size: 4                    # Data point marker size
        font_size: 12                     # Axis label font size
        title_size: 14                    # Plot title font size
        legend_size: 10                   # Legend font size
        grid_alpha: 0.3                   # Grid line transparency (0-1)
        
        # Color scheme (hex codes)
        colors:
          train: "#2196F3"                # Blue - training metrics
          val: "#FF9800"                  # Orange - validation metrics
          test: "#4CAF50"                 # Green - test metrics
          lr: "#9C27B0"                   # Purple - learning rate
  
  # ───────────────────────────────────────────────────────────
  # PREDICTION CONFIGURATION (Phase 5b)
  # ───────────────────────────────────────────────────────────
  # Post-training inference settings for prediction mode.
  # These settings define defaults that can be overridden via CLI.
  #
  # CLI Usage:
  #   python main.py --predict --model-path ./model.pt --test-path ./data.csv
  #
  # DYNAMIC: Supports multiple input formats via DataConverterRegistry
  # PRODUCTION-READY: Comprehensive defaults with CLI override support
  # FUTURE-PROOF: New formats auto-supported via registry pattern
  # ───────────────────────────────────────────────────────────
  
  prediction:
    # =========================================================================
    # MASTER SWITCH
    # =========================================================================
    # NOTE: Prediction mode is triggered via CLI (--predict), not config.
    # This section provides default values that CLI can override.
    # =========================================================================
    
    # =========================================================================
    # RUNTIME CONFIGURATION
    # =========================================================================
    # Default batch size for inference
    # CLI Override: --predict-batch-size
    batch_size: 32
    
    # Device selection for inference
    # Options: "auto", "cpu", "cuda", "mps"
    # CLI Override: --predict-device
    device: "auto"
    
    # =========================================================================
    # INPUT CONFIGURATION
    # =========================================================================
    # Input format auto-detection (recommended)
    # Options: "auto", "smiles", "inchi", "xyz", "sdf", "csv", "dataset"
    # CLI Override: --predict-format
    format: "auto"
    
    # Dataset split to predict on (only for miliaDataset inputs)
    # Options: "all", "train", "val", "test"
    # CLI Override: --predict-split
    split: "all"
    
    # Limit number of samples for prediction
    # null = all samples, integer = limit to N samples
    # CLI Override: --predict-num-samples
    num_samples: null
    
    # =========================================================================
    # OUTPUT CONFIGURATION
    # =========================================================================
    # Default path to save predictions
    # CLI Override: --preds-path
    output_path: "./predictions.csv"
    
    # Output format for predictions
    # Options: "csv", "json", "npy", "pt"
    # CLI Override: --predict-output-format
    output_format: "csv"
    
    # Include input identifiers in output (e.g., SMILES strings)
    # CLI Override: --predict-include-inputs
    include_inputs: false
    
    # =========================================================================
    # UNCERTAINTY ESTIMATION
    # =========================================================================
    # Enable uncertainty estimation (if model supports)
    # CLI Override: --predict-uncertainty
    uncertainty: false
    
    # Uncertainty method (for models that support multiple methods)
    # Options: "dropout", "ensemble", "evidential"
    uncertainty_method: "dropout"
    
    # Number of forward passes for dropout-based uncertainty
    num_dropout_samples: 10
    
    # =========================================================================
    # POST-PROCESSING
    # =========================================================================
    # Apply inverse transform to predictions (if model was trained with scaling)
    inverse_transform: true
    
    # Round predictions to specified decimal places (null = no rounding)
    round_decimals: null
    
    # =========================================================================
    # LOGGING
    # =========================================================================
    # Verbosity level for prediction
    # Options: "quiet", "normal", "verbose"
    verbosity: "normal"
    
    # Log progress every N batches (0 = no progress logging)
    log_every_n_batches: 10

  # ───────────────────────────────────────────────────────────
  # HPO (Hyperparameter Optimization) Configuration
  # ───────────────────────────────────────────────────────────
  # This section configures HPO settings (trials, sampler, search space, etc.)
  # The hpo/ module handles optimization ONLY - it does NOT manage config.
  
  hpo:
    # =========================================================================
    # MASTER SWITCH - Pipeline Inclusion Control
    # =========================================================================
    # Controls whether HPO is included in the training pipeline workflow.
    # - false (default): Standard training runs (single model, fixed hyperparameters)
    # - true: HPO runs (hyperparameter search across multiple trials)
    #
    # CLI Override: --hpo (enable) / --no-hpo (disable) takes precedence
    # Priority: CLI > Config > Default (false)
    #
    # NOTE: This is a PIPELINE CONFIGURATION setting, not an hpo/ module setting.
    #       The hpo/ module provides optimization functionality when invoked,
    #       but does NOT determine when/whether HPO runs.
    # =========================================================================
    enabled: false                  # Test57: HPO disabled - ARGA + ARGVA ensemble
    
    # =========================================================================
    # BACKEND CONFIGURATION
    # =========================================================================
    backend: "optuna"                 # "optuna" (primary) or "ray_tune" (future)
    n_trials: 3                        # LOW RESOURCE - 3 trials only
    timeout: 120                       # LOW RESOURCE - 120s max
    n_jobs: 1                          # Parallel trials (1 = sequential)
    
    # =========================================================================
    # SEARCH SPACE DEFINITION
    # =========================================================================
    # Suggested Universe of Model HyperParameters
    # Define hyperparameters to optimize and their ranges.
    # Categories: hyperparameters, optimizer, scheduler, loss
    # NOTE: Parameters not applicable to the selected model are automatically
    #       filtered at runtime (e.g., 'heads' is skipped for GCN models).
    
    search_space:
      # Model hyperparameters
      hyperparameters:
        hidden_channels:
          type: "int"
          low: 32
          high: 256
          step: 32
        
        num_layers:
          type: "int"
          low: 2
          high: 6
        
        dropout:
          type: "float"
          low: 0.0
          high: 0.7
        
        heads:                        # For attention models (GAT, etc.)
          type: "int"
          low: 1
          high: 8
      
      # Optimizer hyperparameters
      optimizer:
        lr:
          type: "loguniform"
          low: 1.0e-5
          high: 1.0e-2
        
        weight_decay:
          type: "loguniform"
          low: 1.0e-6
          high: 1.0e-3
      
      # Scheduler hyperparameters
      scheduler:
        factor:
          type: "float"
          low: 0.1
          high: 0.9
        
        patience:
          type: "int"
          low: 5
          high: 20
      
      # Loss function hyperparameters (for focal loss, etc.)
      loss:
        alpha:
          type: "float"
          low: 0.1
          high: 0.9
    
    # =========================================================================
    # PRUNER CONFIGURATION
    # =========================================================================
    # Controls early stopping of unpromising trials
    
    pruner:
      type: "median"                  # median, hyperband, percentile, none
      n_startup_trials: 5             # Trials before pruning begins
      n_warmup_steps: 10              # Epochs before pruning within trial
      interval_steps: 1               # Check pruning every N steps
      percentile: 25.0                # For percentile pruner
    
    # =========================================================================
    # SAMPLER CONFIGURATION
    # =========================================================================
    # Controls hyperparameter suggestion strategy
    
    sampler:
      type: "tpe"                     # tpe, random, cmaes, grid
      n_startup_trials: 10            # Random trials before Bayesian
      seed: null                      # Random seed (null = random)
      multivariate: true              # Use multivariate TPE
      constant_liar: false            # For parallel optimization
    
    # =========================================================================
    # STUDY CONFIGURATION
    # =========================================================================
    # Optuna study settings
    
    study:
      direction: "minimize"           # minimize or maximize
      metric: "val_loss"              # Metric to optimize
      study_name: "milia_hpo"         # Study name for persistence
      storage: null                   # null = in-memory
                                      # "sqlite:///hpo_results.db" for persistence
      load_if_exists: true            # Resume existing study
    
    # =========================================================================
    # CROSS-VALIDATION
    # =========================================================================
    # Optional k-fold CV for more robust evaluation
    
    cv_folds: 0                       # 0 = no CV, >0 = k-fold CV
    cv_metric_aggregation: "mean"     # mean, median, min, max
  
  # ───────────────────────────────────────────────────────────
  # ACCELERATION (Optional - Default: Disabled)
  # ───────────────────────────────────────────────────────────
  
  acceleration:
    enabled: false                       # ⚠️ Set to true to enable
    
    # Device Configuration
    device:
      type: "auto"                       # auto, cpu, cuda, mps, tpu
      gpu_ids: [0]                       # For multi-GPU: [0, 1, 2, 3]
      allow_fallback: true               # Fallback to CPU if device unavailable
    
    # Distributed Training (Single/Multi-Node)
    distributed:
      enabled: false
      strategy: "ddp"                    # ddp, fsdp, deepspeed, horovod, none
      
      # DDP Configuration
      ddp:
        find_unused_parameters: false
        gradient_as_bucket_view: true
      
      # FSDP Configuration
      fsdp:
        sharding_strategy: "full_shard"  # full_shard, shard_grad_op, no_shard
        cpu_offload: false
        backward_prefetch: true
      
      # DeepSpeed Configuration
      deepspeed:
        enabled: false
        config_path: null                # Path to DeepSpeed JSON config
        zero_stage: 2                    # 0, 1, 2, 3
        offload_optimizer: false
        offload_param: false
      
      # Multi-Node Configuration
      num_nodes: 1
      world_size: 1                      # Total processes (num_nodes * gpus_per_node)
      node_rank: 0                       # Rank of current node
      master_addr: "localhost"
      master_port: 12355
    
    # Memory Optimization
    memory:
      mixed_precision: "no"              # no, fp16, bf16, fp8 (if supported)
      gradient_checkpointing: false
      gradient_accumulation_steps: 1
      max_memory_per_gpu: null           # null = auto, or specify in GB
      empty_cache_interval: 0            # Clear cache every N batches (0 = disabled)
    
    # Computation Optimization
    computation:
      compile_model: false               # torch.compile (PyTorch 2.0+)
      compile_mode: "default"            # default, reduce-overhead, max-autotune
      use_cudnn_benchmark: true          # Enable cuDNN auto-tuner
      enable_tf32: true                  # TensorFloat-32 on Ampere+ GPUs
      
      # DataLoader Optimization
      dataloader:
        num_workers: 4
        pin_memory: true
        prefetch_factor: 2
        persistent_workers: false
  
  # ───────────────────────────────────────────────────────────
  # DEPLOYMENT & OPTIMIZATION (Optional - Default: Disabled)
  # ───────────────────────────────────────────────────────────
  
  deployment:
    enabled: false                       # ⚠️ Set to true to enable
    
    # Model Optimization
    optimization:
      # Quantization
      quantization:
        enabled: false
        method: "dynamic"                # dynamic, static, qat (quantization-aware)
        backend: "fbgemm"                # fbgemm (x86), qnnpack (ARM)
        dtype: "qint8"                   # qint8, quint8, float16
      
      # Pruning
      pruning:
        enabled: false
        method: "magnitude"              # magnitude, l1_unstructured, random
        amount: 0.3                      # Sparsity level (0.0-1.0)
        iterative: false
        iterations: 5
      
      # Knowledge Distillation
      distillation:
        enabled: false
        teacher_checkpoint: null         # Path to teacher model
        temperature: 3.0
        alpha: 0.5                       # Weight for distillation loss
    
    # Deployment Strategy
    strategy: "cloud"                    # local, cloud, edge, federated, serverless
    
    # Edge Deployment
    edge:
      target_device: "jetson_nano"       # jetson_nano, raspberry_pi, coral, custom
      optimization_level: "balanced"     # speed, balanced, size
    
    # Cloud Deployment
    cloud:
      provider: null                     # aws, gcp, azure, local
      instance_type: null                # e.g., p3.2xlarge, n1-highmem-8
      accelerator: "gpu"                 # gpu, tpu, trainium, inferentia
      auto_scaling: false
      min_instances: 1
      max_instances: 10
    
    # Federated Learning
    federated:
      num_clients: 10
      rounds: 50
      aggregation: "fedavg"              # fedavg, fedprox, fedadam
      client_selection: "random"
    
    # Monitoring
    monitoring:
      enabled: true
      metrics:
        - "inference_latency"
        - "throughput"
        - "memory_usage"
        - "prediction_accuracy"
      
      # Drift Detection
      drift_detection:
        enabled: true
        method: "statistical"            # statistical, model_based
        threshold: 0.1
      
      # Retraining
      retraining:
        enabled: false
        trigger: "manual"                # drift, schedule, manual, performance
        schedule: null                   # e.g., "0 0 * * 0" (weekly cron)
        performance_threshold: 0.05      # Retrain if performance drops > 5%
  
  # ───────────────────────────────────────────────────────────
  # PLUGIN SYSTEM
  # ───────────────────────────────────────────────────────────
  
  plugins:
    enabled: true
    plugin_paths:
      - ./plugins/models
    auto_discover: true
    auto_validate: true
    validation_level: "standard"         # permissive, standard, strict

# ──────────────────── # This Not the end, This is not the beginning of the end, 
# END OF CONFIGURATION # Tshis is the end of the beginning! 
# ──────────────────── # Be it So!
